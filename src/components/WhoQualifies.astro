---
const qualifyItems = [
  'Credit score 660 or higher (some programs go to 620)',
  'Down payment of 20% or more',
  'Property generates rental income (or you put 30%+ down for No-Ratio)',
  'Non-owner-occupied investment property',
  '6 months of reserves in liquid assets',
  'SFR, 2-8 unit, condo, townhome, or mixed-use',
  'US citizen, permanent resident, or foreign national',
  'Self-employed, W-2, retired, or any income source',
  'Closing in personal name, LLC, or trust',
  'No limit on number of financed properties',
];

const notIdealItems = [
  'Credit score below 620 (most lenders require 660+)',
  'Down payment under 15% (minimum is 20%, or 30% for No-Ratio)',
  'You plan to live in the property (DSCR is investment-only)',
  'The property is raw land or commercial (DSCR covers residential 1-8 units)',
  'You need fix-and-flip-only financing (see Bridge-to-DSCR for rehab-to-hold)',
];
---

<section id="who-qualifies" class="relative bg-off-white py-16 md:py-24 overflow-hidden">
  <!-- Subtle background image -->
  <div class="absolute inset-0">
    <img src="/images/sections/who-qualifies.jpg" alt="" class="w-full h-full object-cover opacity-[0.05]" aria-hidden="true" />
  </div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-3xl text-center">
      <p data-gsap="eyebrow" class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">QUALIFICATION</p>
      <h2 data-gsap="heading" class="text-3xl font-bold tracking-tight text-navy md:text-4xl">Who Qualifies for a DSCR Loan</h2>
      <p data-gsap="subhead" class="mt-4 text-lg text-gray-500">DSCR loans qualify the property, not you. If the rent covers the payment, you qualify.</p>
    </div>

    <!-- Two-column grid -->
    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2">
      <!-- You Qualify If -->
      <div data-gsap="card" class="rounded-xl border border-gray-200 bg-white p-6 md:p-8">
        <div class="flex items-center gap-2 mb-5">
          <svg class="h-5 w-5 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h3 class="text-lg font-semibold text-navy">You Qualify If</h3>
        </div>
        <ul class="space-y-3">
          {qualifyItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm leading-relaxed text-gray-500">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- This May Not Be Ideal If -->
      <div data-gsap="card" class="rounded-xl border border-gray-200 bg-white p-6 md:p-8">
        <div class="flex items-center gap-2 mb-5">
          <svg class="h-5 w-5 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h3 class="text-lg font-semibold text-navy">This May Not Be Ideal If</h3>
        </div>
        <ul class="space-y-3">
          {notIdealItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span class="text-sm leading-relaxed text-gray-500">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center">
      <a
        href="/qualify/"
        class="inline-flex items-center rounded-lg bg-blue px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        Check My Eligibility
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
