---
const currentYear = new Date().getFullYear();

const programLinks = [
  { label: 'Standard DSCR', href: '/programs/standard-dscr/' },
  { label: 'No-Ratio DSCR', href: '/programs/no-ratio-dscr/' },
  { label: 'Foreign National', href: '/programs/foreign-national-dscr/' },
  { label: 'Interest-Only', href: '/programs/interest-only-dscr/' },
  { label: 'Bank Statement', href: '/programs/bank-statement-dscr/' },
  { label: 'Short-Term Rental', href: '/programs/short-term-rental-dscr/' },
  { label: 'Portfolio DSCR', href: '/programs/portfolio-dscr/' },
  { label: 'Bridge-to-DSCR', href: '/programs/bridge-to-dscr/' },
];

const resourceLinks = [
  { label: 'DSCR Calculator', href: '/calculator/' },
  { label: 'Learn Center', href: '/learn/' },
  { label: 'State Coverage', href: '/states/' },
  { label: 'About Us', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy/' },
  { label: 'Terms of Service', href: '/terms-of-service/' },
];
---

<footer class="bg-navy border-t border-navy-mid">
  <!-- Main footer grid -->
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 md:py-16">
    <div class="grid gap-8 md:grid-cols-4">
      <!-- Column 1: Brand -->
      <div class="md:col-span-1">
        <a href="/" class="inline-flex items-baseline gap-0">
          <span class="text-xl font-extrabold text-white">DSCRBroker</span>
          <span class="text-xl font-normal text-blue">.com</span>
        </a>
        <p class="mt-3 text-sm text-slate-400">
          DSCRBroker.com is a matching service, not a lender or mortgage broker.
        </p>
        {/* PLACEHOLDER: Phone number */}
        <a
          href="tel:+10000000000"
          class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-slate-300 transition-colors hover:text-white"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (XXX) XXX-XXXX
        </a>
      </div>

      <!-- Column 2: Loan Programs -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-400">Loan Programs</h4>
        <ul class="mt-4 space-y-2">
          {programLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-300 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Resources -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-400">Resources</h4>
        <ul class="mt-4 space-y-2">
          {resourceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-300 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Get Started -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-400">Get Started</h4>
        <div class="mt-4 space-y-3">
          <a
            href="/qualify/"
            class="flex items-center justify-center rounded-lg bg-blue px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-blue-dark"
          >
            Match Me With a Specialist
          </a>
          <a
            href="/calculator/"
            class="flex items-center justify-center rounded-lg border border-navy-mid px-4 py-2.5 text-sm font-medium text-slate-300 transition-colors hover:border-blue hover:text-white"
          >
            Calculate My DSCR
          </a>
        </div>
        <div class="mt-6 space-y-1">
          {legalLinks.map((link) => (
            <a href={link.href} class="block text-xs text-slate-400 underline transition-colors hover:text-slate-300">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Disclaimer bar -->
  <div class="border-t border-navy-mid">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8 space-y-4">
      <!-- Core disclaimer -->
      <p class="text-xs text-slate-400 max-w-4xl mx-auto text-center leading-relaxed">
        DSCRBroker.com is a referral and matching service. We are not a lender, bank, or mortgage broker. We connect borrowers with licensed DSCR loan professionals. All loan decisions are made by the matched broker and their wholesale lending partners. Loan terms and approval are subject to individual lender guidelines and borrower qualifications. DSCRBroker.com does not charge borrowers any fees.
      </p>

      <!-- Equal Housing Opportunity -->
      <div class="flex items-start justify-center gap-3 text-xs text-slate-400 max-w-4xl mx-auto">
        <!-- EHO Logo SVG -->
        <svg class="h-6 w-6 flex-shrink-0 fill-slate-400" viewBox="0 0 24 24" aria-label="Equal Housing Opportunity">
          <path d="M12 2L2 10h3v10h14V10h3L12 2zm0 2.84L18 10v10H6V10l6-5.16zM11 12h2v6h-2v-6z" />
        </svg>
        <p class="leading-relaxed">
          Equal Housing Opportunity. All participating brokers in the DSCRBroker.com network are equal opportunity lenders. Loans are available regardless of race, color, religion, national origin, sex, handicap, or familial status, in accordance with the Fair Housing Act.
        </p>
      </div>

      <!-- Copyright -->
      <p class="text-center text-xs text-slate-500">
        &copy; {currentYear} DSCRBroker.com. All rights reserved. {/* PLACEHOLDER: NMLS #XXXXXX */}
      </p>
    </div>
  </div>
</footer>
