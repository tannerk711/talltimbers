---
const currentYear = new Date().getFullYear();
const PHONE = '(888) 931-0211';
const phoneHref = `tel:${PHONE.replace(/\D/g, '')}`;

const stateLinks = [
  { label: 'Florida DSCR', href: '/lp/florida-dscr/' },
  { label: 'Georgia DSCR', href: '/lp/georgia-dscr/' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy/' },
  { label: 'Terms of Service', href: '/terms-of-service/' },
];
---

<footer class="bg-navy border-t border-navy-mid">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 md:py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <!-- Column 1: Brand -->
      <div>
        <a href="/" class="flex items-center gap-2.5">
          <img src="/images/tall-timbers-logo.png" alt="Tall Timbers Realty and Financial Services" class="h-10 w-auto" />
          <span class="text-base font-bold text-white">Tall Timbers RFS</span>
        </a>
        <p class="mt-4 text-sm text-white/60 leading-relaxed">
          DSCR investor loans. 250+ closed across a 70+ lender network. Consultative on the first call.
        </p>
        <a
          href={phoneHref}
          class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-white/80 transition-colors hover:text-white"
        >
          <svg class="h-4 w-4 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {PHONE}
        </a>
      </div>

      <!-- Column 2: State LPs -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-white/50">Where We Work</h4>
        <ul class="mt-4 space-y-2">
          {stateLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/70 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Get Started -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-white/50">Get Started</h4>
        <div class="mt-4 space-y-3">
          <a
            href="/#states"
            class="flex items-center justify-center rounded-lg bg-blue px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-blue-dark"
          >
            Check Your Eligibility
          </a>
          <a
            href={phoneHref}
            class="flex items-center justify-center rounded-lg border border-white/20 px-4 py-2.5 text-sm font-medium text-white/80 transition-colors hover:border-blue hover:text-white"
          >
            Call {PHONE}
          </a>
        </div>
        <div class="mt-6 space-y-1.5">
          {legalLinks.map((link) => (
            <a href={link.href} class="block text-xs text-white/50 underline transition-colors hover:text-white/80">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Disclaimer bar -->
  <div class="border-t border-navy-mid">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8 space-y-4">
      <p class="text-xs text-white/50 max-w-4xl mx-auto text-center leading-relaxed">
        Tall Timbers Realty and Financial Services originates DSCR and non-QM loans for real estate investors. Pre-qualification is based on the information you provide. Final approval is subject to underwriting, appraisal, and lender guidelines. This is not a commitment to lend. Licensed mortgage activity is performed by Adam C. Cunningham, Mortgage Loan Originator, NMLS #312817.
      </p>

      <div class="flex items-start justify-center gap-3 text-xs text-white/50 max-w-4xl mx-auto">
        <svg class="h-6 w-6 flex-shrink-0 fill-white/50" viewBox="0 0 24 24" aria-label="Equal Housing Opportunity">
          <path d="M12 2L2 10h3v10h14V10h3L12 2zm0 2.84L18 10v10H6V10l6-5.16zM11 12h2v6h-2v-6z" />
        </svg>
        <p class="leading-relaxed">
          Equal Housing Opportunity. Loans are available regardless of race, color, religion, national origin, sex, handicap, or familial status, in accordance with the Fair Housing Act.
        </p>
      </div>

      <p class="text-center text-xs text-white/40">
        &copy; {currentYear} Tall Timbers Realty and Financial Services. All rights reserved. NMLS #312817.
      </p>
    </div>
  </div>
</footer>
