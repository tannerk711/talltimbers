---
import MobileNav from './MobileNav';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 h-16 md:h-20 bg-transparent transition-all duration-300"
>
  <div class="mx-auto flex h-full max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-baseline gap-0">
      <span class="text-xl font-extrabold text-white">DSCRBroker</span>
      <span class="text-xl font-normal text-blue">.com</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      <a href="/programs/" class="text-sm font-medium text-slate-300 transition-colors hover:text-white">
        Loan Programs
      </a>
      <a href="/analyze/" class="text-sm font-medium text-slate-300 transition-colors hover:text-white">
        Deal Analyzer
      </a>
      <a href="/states/" class="text-sm font-medium text-slate-300 transition-colors hover:text-white">
        States
      </a>
      <a href="/learn/" class="text-sm font-medium text-slate-300 transition-colors hover:text-white">
        Learn
      </a>
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden md:block">
      <a
        href="/qualify/"
        class="inline-flex items-center rounded-lg bg-blue px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        Match Me With a Specialist
      </a>
    </div>

    <!-- Mobile CTA + Nav -->
    <div class="flex items-center gap-2 md:hidden">
      <a
        href="/qualify/"
        class="inline-flex items-center rounded-lg bg-blue px-3 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        Get Started
      </a>
      <MobileNav client:load />
    </div>
  </div>
</header>

<!-- Header scroll behavior -->
<script>
  const header = document.getElementById('site-header');
  if (header) {
    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (window.scrollY > 50) {
            header.classList.add('bg-navy/95', 'backdrop-blur-md', 'border-b', 'border-navy-mid');
            header.classList.remove('bg-transparent');
          } else {
            header.classList.remove('bg-navy/95', 'backdrop-blur-md', 'border-b', 'border-navy-mid');
            header.classList.add('bg-transparent');
          }
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
