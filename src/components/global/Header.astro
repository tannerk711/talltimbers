---
const PHONE = '(888) 931-0211';
const phoneHref = `tel:${PHONE.replace(/\D/g, '')}`;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 h-16 md:h-20 bg-transparent transition-all duration-300"
>
  <div class="mx-auto flex h-full max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5">
      <img src="/images/tall-timbers-logo.png" alt="Tall Timbers Realty and Financial Services" class="h-9 md:h-10 w-auto" />
      <span class="text-base md:text-lg font-bold text-white hidden sm:inline">Tall Timbers RFS</span>
    </a>

    <!-- Desktop: Phone + CTA -->
    <div class="hidden md:flex items-center gap-4">
      <a href={phoneHref} class="inline-flex items-center gap-2 text-sm font-medium text-white/80 transition-colors hover:text-white">
        <svg class="h-4 w-4 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-1.86.93a11 11 0 005.2 5.2l.93-1.86a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z" />
        </svg>
        {PHONE}
      </a>
      <a
        href="/#states"
        class="inline-flex items-center rounded-lg bg-blue px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        Check Your Eligibility
      </a>
    </div>

    <!-- Mobile CTA -->
    <div class="flex items-center gap-2 md:hidden">
      <a href={phoneHref} class="inline-flex items-center justify-center rounded-lg bg-white/[0.08] border border-white/15 h-9 w-9 transition-colors hover:bg-white/15" aria-label="Call us">
        <svg class="h-4 w-4 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-1.86.93a11 11 0 005.2 5.2l.93-1.86a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z" />
        </svg>
      </a>
      <a
        href="/#states"
        class="inline-flex items-center rounded-lg bg-blue px-3 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        Get Started
      </a>
    </div>
  </div>
</header>

<!-- Header scroll behavior -->
<script>
  const header = document.getElementById('site-header');
  if (header) {
    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (window.scrollY > 50) {
            header.classList.add('bg-navy/95', 'backdrop-blur-md', 'border-b', 'border-navy-mid');
            header.classList.remove('bg-transparent');
          } else {
            header.classList.remove('bg-navy/95', 'backdrop-blur-md', 'border-b', 'border-navy-mid');
            header.classList.add('bg-transparent');
          }
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
