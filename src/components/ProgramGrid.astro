---
// ProgramGrid — single-broker version for Tall Timbers RFS.
// Photo-banner cards, no per-card links (we are not a directory),
// no hard stat numbers (Adam quotes real overlays per-file 1:1),
// 3 feature bullets per card. Tall Timbers "we" voice.

const icons: Record<string, string> = {
  'standard-dscr': `<path d="M3 11l9-7 9 7"/><path d="M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/><path d="M15 7V4h-2"/>`,
  'no-ratio-dscr': `<circle cx="12" cy="14" r="4"/><path d="M9.17 16.83l5.66-5.66"/><path d="M3 11l9-7 9 7"/>`,
  'foreign-national-dscr': `<circle cx="12" cy="12" r="9"/><path d="M3.6 9h16.8M3.6 15h16.8"/><ellipse cx="12" cy="12" rx="4" ry="9"/>`,
  'interest-only-dscr': `<path d="M3 7l4 4 4-4 6 6"/><path d="M17 13V7h-6"/><line x1="3" y1="20" x2="21" y2="20"/>`,
  'str-dscr': `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18"/><path d="M16 2v4M8 2v4"/><path d="M12 14.5l-1.5 1.5h3L12 14.5zM12 14.5l1.5-1.5h-3l1.5 1.5z"/>`,
  'portfolio-dscr': `<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 12l10 5 10-5"/><path d="M2 17l10 5 10-5"/>`,
};

const programs = [
  {
    name: 'Standard DSCR',
    slug: 'standard-dscr',
    features: [
      'Qualify on the property, not your income',
      'SFR, 2-8 unit, condo, townhome',
      'No cap on financed properties',
    ],
    image: '/images/programs/standard-dscr.jpg',
    imageAlt: 'Single-family rental home at golden hour',
    highlight: true,
    highlightLabel: 'Most Common',
  },
  {
    name: 'No-Ratio DSCR',
    slug: 'no-ratio-dscr',
    features: [
      'Negative cash flow deals still qualify',
      'No DSCR calculation gate',
      'Built for appreciation plays',
    ],
    image: '/images/programs/no-ratio-dscr.jpg',
    imageAlt: 'Modern luxury home at dusk with glowing interior',
  },
  {
    name: 'Foreign National DSCR',
    slug: 'foreign-national-dscr',
    features: [
      'No US credit history required',
      'Foreign bank reference letter accepted',
      'No SSN or US visa needed',
    ],
    image: '/images/programs/foreign-national-dscr.jpg',
    imageAlt: 'Aerial view of waterfront properties along tropical coastline',
  },
  {
    name: 'Interest-Only DSCR',
    slug: 'interest-only-dscr',
    features: [
      'Lower payments lift your DSCR',
      '5-year and 10-year IO periods',
      'Maximize monthly cash flow',
    ],
    image: '/images/programs/interest-only-dscr.jpg',
    imageAlt: 'Gold house keys and coins representing lower payments',
  },
  {
    name: 'Short-Term Rental DSCR',
    slug: 'str-dscr',
    features: [
      'Airbnb and VRBO income accepted',
      'AirDNA projections qualify the deal',
      'Vacation markets nationwide',
    ],
    image: '/images/programs/str-dscr.jpg',
    imageAlt: 'Luxury cabin vacation rental with mountain view and fireplace',
  },
  {
    name: 'Portfolio DSCR',
    slug: 'portfolio-dscr',
    features: [
      'Bundle 3-20+ properties in one loan',
      'Aggregate DSCR across the portfolio',
      'One payment, one closing',
    ],
    image: '/images/programs/portfolio-dscr.jpg',
    imageAlt: 'Aerial view of suburban neighborhood with rows of rental homes',
  },
];
---

<section id="programs" class="bg-off-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p data-fl-reveal class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">LOAN PROGRAMS</p>
      <h2 data-fl-reveal class="text-3xl font-bold tracking-tight text-navy md:text-4xl">DSCR Programs Built for Every Deal Type</h2>
      <p data-fl-reveal class="mt-4 text-lg text-gray-500">We work the full DSCR product stack across a 70+ lender network. Whatever your scenario looks like, there's a structure that fits.</p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {programs.map((program) => (
        <div
          data-fl-reveal
          class={`flex flex-col overflow-hidden rounded-xl border bg-white shadow-sm transition-shadow duration-200 hover:shadow-lg ${program.highlight ? 'border-blue-light/40 ring-1 ring-blue-light/20' : 'border-gray-200'}`}
        >
          <div class="relative h-40 overflow-hidden">
            <img
              src={program.image}
              alt={program.imageAlt}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/15 to-transparent" />
            <div class="absolute top-3 left-3 w-9 h-9 rounded-lg bg-white/90 backdrop-blur-sm flex items-center justify-center shadow-sm">
              <svg class="w-[18px] h-[18px] text-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[program.slug]} />
            </div>
            <div class="absolute bottom-3 left-3">
              <h3 class="text-base font-semibold text-white drop-shadow-md">{program.name}</h3>
            </div>
            {program.highlight && (
              <span class="absolute top-3 right-3 bg-blue text-white text-[9px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded shadow-sm">
                {program.highlightLabel}
              </span>
            )}
          </div>

          <div class="flex-1 px-5 py-5">
            <ul class="space-y-2.5">
              {program.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a
        href="#lead-form"
        data-event="scroll_to_form"
        data-location="after_programs"
        class="inline-flex items-center rounded-lg bg-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        Check Your Eligibility
        <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
