---
const icons: Record<string, string> = {
  'standard-dscr': `<path d="M3 11l9-7 9 7"/><path d="M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/><path d="M15 7V4h-2"/>`,
  'no-ratio-dscr': `<circle cx="12" cy="14" r="4"/><path d="M9.17 16.83l5.66-5.66"/><path d="M3 11l9-7 9 7"/>`,
  'foreign-national-dscr': `<circle cx="12" cy="12" r="9"/><path d="M3.6 9h16.8M3.6 15h16.8"/><ellipse cx="12" cy="12" rx="4" ry="9"/>`,
  'interest-only-dscr': `<path d="M3 7l4 4 4-4 6 6"/><path d="M17 13V7h-6"/><line x1="3" y1="20" x2="21" y2="20"/>`,
  'str-dscr': `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18"/><path d="M16 2v4M8 2v4"/><path d="M12 14.5l-1.5 1.5h3L12 14.5zM12 14.5l1.5-1.5h-3l1.5 1.5z"/>`,
  'portfolio-dscr': `<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 12l10 5 10-5"/><path d="M2 17l10 5 10-5"/>`,
};

const programs = [
  {
    name: 'Standard DSCR',
    slug: 'standard-dscr',
    stats: { dscr: '1.0x', down: '20%', fico: '660', maxLTV: '80%' },
    features: [
      'No income docs or tax returns',
      'SFR, 2-8 unit, condo, townhome',
      'No limit on financed properties',
    ],
    image: '/images/programs/standard-dscr.jpg',
    imageAlt: 'Single-family rental home at golden hour',
    highlight: true,
  },
  {
    name: 'No-Ratio DSCR',
    slug: 'no-ratio-dscr',
    stats: { dscr: 'None', down: '30%', fico: '680', maxLTV: '70%' },
    features: [
      'Negative cash flow properties qualify',
      'No DSCR calculation required',
      'Best for appreciation markets',
    ],
    image: '/images/programs/no-ratio-dscr.jpg',
    imageAlt: 'Modern luxury home at dusk with glowing interior',
  },
  {
    name: 'Foreign National DSCR',
    slug: 'foreign-national-dscr',
    stats: { dscr: '1.0x', down: '25%', fico: 'N/A', maxLTV: '75%' },
    features: [
      'No US credit history needed',
      'Foreign bank reference letter accepted',
      'No SSN or US visa required',
    ],
    image: '/images/programs/foreign-national-dscr.jpg',
    imageAlt: 'Aerial view of waterfront properties along tropical coastline',
  },
  {
    name: 'Interest-Only DSCR',
    slug: 'interest-only-dscr',
    stats: { dscr: '1.0x', down: '20%', fico: '680', maxLTV: '80%' },
    features: [
      'Lower payments boost your DSCR',
      '5-year or 10-year IO periods',
      'Maximize monthly cash flow',
    ],
    image: '/images/programs/interest-only-dscr.jpg',
    imageAlt: 'Gold house keys and coins representing lower payments',
  },
  {
    name: 'Short-Term Rental DSCR',
    slug: 'str-dscr',
    stats: { dscr: '1.0x', down: '20%', fico: '680', maxLTV: '80%' },
    features: [
      'Airbnb and VRBO income accepted',
      'AirDNA projections qualify the deal',
      'Vacation markets nationwide',
    ],
    image: '/images/programs/str-dscr.jpg',
    imageAlt: 'Luxury cabin vacation rental with mountain view and fireplace',
  },
  {
    name: 'Portfolio DSCR',
    slug: 'portfolio-dscr',
    stats: { dscr: '1.0x', down: '25%', fico: '680', maxLTV: '75%' },
    features: [
      'Bundle 3-20+ properties in one loan',
      'Aggregate DSCR across all properties',
      'One payment, one closing',
    ],
    image: '/images/programs/portfolio-dscr.jpg',
    imageAlt: 'Aerial view of suburban neighborhood with rows of rental homes',
  },
];
---

<section id="programs" class="bg-off-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-3xl text-center">
      <p data-gsap="eyebrow" class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">LOAN PROGRAMS</p>
      <h2 data-gsap="heading" class="text-3xl font-bold tracking-tight text-navy md:text-4xl">DSCR Programs for Every Deal Type</h2>
      <p data-gsap="subhead" class="mt-4 text-lg text-gray-500">8 programs. 50+ lenders. Every property type and investor scenario covered.</p>
    </div>

    <!-- Program grid -->
    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {programs.map((program) => (
        <a
          href={`/programs/${program.slug}/`}
          data-gsap="tile"
          class={`group flex flex-col overflow-hidden rounded-xl border bg-white shadow-sm transition-all duration-200 hover:shadow-lg ${program.highlight ? 'border-blue-200 ring-1 ring-blue-100' : 'border-gray-200'}`}
        >
          {/* Photo banner with icon overlay */}
          <div class="relative h-40 overflow-hidden">
            <img
              src={program.image}
              alt={program.imageAlt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent" />
            {/* Icon badge */}
            <div class="absolute top-3 left-3 w-9 h-9 rounded-lg bg-white/90 backdrop-blur-sm flex items-center justify-center shadow-sm">
              <svg class="w-[18px] h-[18px] text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[program.slug]} />
            </div>
            {/* Program name on image */}
            <div class="absolute bottom-3 left-3">
              <h3 class="text-base font-semibold text-white drop-shadow-md">{program.name}</h3>
            </div>
            {program.highlight && (
              <span class="absolute top-3 right-3 bg-blue-500 text-white text-[9px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded shadow-sm">
                Most Popular
              </span>
            )}
          </div>

          {/* Stats grid */}
          <div class="grid grid-cols-2 gap-4 border-b border-gray-100 p-5">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Min DSCR</p>
              <p class="mt-1 text-lg font-semibold text-navy">{program.stats.dscr}</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Min Down</p>
              <p class="mt-1 text-lg font-semibold text-navy">{program.stats.down}</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Min FICO</p>
              <p class="mt-1 text-lg font-semibold text-navy">{program.stats.fico}</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Max LTV</p>
              <p class="mt-1 text-lg font-semibold text-blue">{program.stats.maxLTV}</p>
            </div>
          </div>

          {/* Feature bullets */}
          <div class="flex-1 px-5 py-4">
            <ul class="space-y-2.5">
              {program.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-gray-500">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>

          {/* CTA */}
          <div class="px-5 pb-5">
            <span class="inline-flex items-center gap-1 text-sm font-medium text-blue transition-colors group-hover:text-blue-dark">
              Learn More
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- See all programs CTA -->
    <div class="mt-8 text-center">
      <a href="/programs/" class="inline-flex items-center gap-1 font-medium text-blue transition-colors hover:text-blue-dark">
        See All 8 Programs
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
