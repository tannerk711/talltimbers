---
// SpecialistCard for Tall Timbers RFS — single-broker company mode.
// On the LP: Tall Timbers brand block is the primary visual. Adam appears as a
// "Your specialist" sub-row beneath the bio. Adam's face leads on the thank-you page.

interface Props {
  variant?: 'compact' | 'full';
  theme?: 'dark' | 'light';
  name?: string;
  title?: string;
  nmls?: string;
  brandLogo?: string;
  bio?: string;
  phoneNumber?: string;
  stats?: { label: string; value: string }[];
  specialistLabel?: string;
  ctaLabel?: string;
  specialistName?: string;
  specialistHeadshot?: string;
  specialistRole?: string;
  showSpecialistRow?: boolean;
}

const {
  variant = 'compact',
  theme = 'dark',
  name = 'Tall Timbers Realty and Financial Services',
  title = 'DSCR Investor Loans',
  nmls = 'NMLS #312817',
  brandLogo = '/images/tall-timbers-logo.png',
  bio = "We've closed 250+ DSCR and non-QM loans for real estate investors, including the ones whose first lender already said no. We're consultative on the first call: we walk you through condo warrantability, STR zoning, BRRRR refi timing, and the lender-specific overlays that actually matter before you write the offer.",
  phoneNumber = '(888) 931-0211',
  stats = [
    { label: 'DSCR/Non-QM Loans Closed', value: '250+' },
    { label: 'Typical Close', value: 'Fast' },
    { label: 'Lender Network', value: '70+' },
    { label: 'NMLS', value: '#312817' },
  ],
  specialistLabel = 'Tall Timbers',
  ctaLabel = 'Check Your Eligibility',
  specialistName = 'Adam C. Cunningham',
  specialistHeadshot = '/images/adam-cunningham-headshot.png',
  specialistRole = 'Mortgage Loan Originator, NMLS #312817',
  showSpecialistRow = false,
} = Astro.props;

const phoneHref = `tel:${phoneNumber.replace(/\D/g, '')}`;
const isDark = theme === 'dark';

const statIconForLabel = (label: string): string => {
  const l = label.toLowerCase();
  if (l.includes('close')) return 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z';
  if (l.includes('lender') || l.includes('network')) return 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z';
  if (l.includes('nmls')) return 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z';
  return 'M3 12l2-2 4 4 8-8 4 4M3 21h18';
};
---

{variant === 'compact' ? (
  <div class={`flex items-center gap-3 rounded-lg ${isDark ? 'bg-white/[0.04] border border-white/10' : 'bg-white border border-gray-200 shadow-sm'} p-3`}>
    <div class={`flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg ${isDark ? 'bg-white' : 'bg-off-white border border-gray-100'} p-1.5`}>
      <img
        src={brandLogo}
        alt="Tall Timbers RFS logo"
        class="h-full w-full object-contain"
        loading="lazy"
      />
    </div>
    <div class="flex-1 min-w-0">
      <div class={`text-xs uppercase tracking-wider ${isDark ? 'text-blue-light' : 'text-blue'} font-semibold`}>{specialistLabel}</div>
      <div class={`text-sm font-bold ${isDark ? 'text-white' : 'text-navy'} truncate`}>Tall Timbers RFS</div>
      <div class={`text-xs ${isDark ? 'text-white/50' : 'text-gray-500'} truncate`}>{nmls} · {title}</div>
    </div>
  </div>
) : (
  <div class="grid md:grid-cols-[320px_1fr] gap-8 md:gap-10 items-start">
    <!-- Brand block: Tall Timbers logo centered on a clean white card -->
    <div class="relative mx-auto md:mx-0 w-full max-w-[320px]">
      <div class="aspect-square rounded-2xl bg-white ring-1 ring-gray-200 shadow-xl flex items-center justify-center p-10">
        <img
          src={brandLogo}
          alt="Tall Timbers Realty and Financial Services logo"
          class="w-full h-auto object-contain"
          loading="lazy"
        />
      </div>
    </div>

    <div>
      <p class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-2">{title}</p>
      <h3 class="text-2xl md:text-3xl font-bold text-navy">{name}</h3>
      <p class="mt-1 text-sm text-gray-500">{nmls}</p>

      <p class="mt-5 text-base leading-relaxed text-gray-600">{bio}</p>

      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3 md:gap-4">
        {stats.map((s) => (
          <div class="rounded-xl bg-white border border-gray-100 px-4 py-4 shadow-sm flex flex-col items-start">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue/10 text-blue mb-3">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={statIconForLabel(s.label)} />
              </svg>
            </div>
            <div class="text-lg font-extrabold text-navy leading-tight" data-stat-value={s.value}>{s.value}</div>
            <div class="text-[11px] uppercase tracking-wider text-gray-500 mt-2">{s.label}</div>
          </div>
        ))}
      </div>

      {showSpecialistRow && (
        <div class="mt-6 flex items-center gap-4 rounded-xl bg-off-white border border-gray-200 p-4">
          <img
            src={specialistHeadshot}
            alt={specialistName}
            class="h-14 w-14 rounded-full object-cover object-top ring-2 ring-blue/25 flex-shrink-0"
            loading="lazy"
            width="56"
            height="56"
          />
          <div class="flex-1 min-w-0">
            <p class="text-[10px] uppercase tracking-wider text-blue font-semibold">Your Specialist</p>
            <p class="text-sm font-bold text-navy">{specialistName}</p>
            <p class="text-xs text-gray-500">{specialistRole}</p>
          </div>
        </div>
      )}

      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <a
          href="#lead-form"
          data-event="scroll_to_form"
          data-location="specialist_card"
          class="inline-flex items-center justify-center rounded-lg bg-blue px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-dark"
        >
          {ctaLabel}
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={phoneHref}
          data-event="phone_click"
          data-location="specialist_card"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-5 py-3 text-sm font-semibold text-navy transition-colors hover:border-blue hover:text-blue"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-1.86.93a11 11 0 005.2 5.2l.93-1.86a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z" />
          </svg>
          {phoneNumber}
        </a>
      </div>
    </div>
  </div>
)}
