---
interface Props {
  phoneNumber?: string;
}

const { phoneNumber = '(855) 738-1557' } = Astro.props;
const phoneHref = `tel:${phoneNumber.replace(/\D/g, '')}`;
---

<!-- Mobile-only sticky bottom CTA bar. Appears after scrolling past hero. -->
<div
  id="sticky-mobile-cta"
  class="sticky-mobile-chrome fixed bottom-0 left-0 right-0 z-40 lg:hidden bg-navy/95 backdrop-blur-md border-t border-white/[0.08] px-3 py-3 transform translate-y-full transition-transform duration-300"
>
  <div class="grid grid-cols-2 gap-2 max-w-md mx-auto">
    <a
      href={phoneHref}
      data-event="phone_click"
      data-location="sticky_mobile"
      class="flex items-center justify-center gap-2 rounded-lg bg-navy-light border border-white/10 py-3 text-sm font-semibold text-white active:bg-navy-mid"
    >
      <svg class="h-4 w-4 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-1.86.93a11 11 0 005.2 5.2l.93-1.86a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z" />
      </svg>
      Call
    </a>
    <a
      href="#lead-form"
      data-event="scroll_to_form"
      data-location="sticky_mobile"
      class="flex items-center justify-center gap-1 rounded-lg bg-blue py-3 text-sm font-semibold text-white active:bg-blue-dark"
    >
      Match Me
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</div>

<script>
  // Show sticky CTA after user scrolls past the hero (~600px)
  const stickyEl = document.getElementById('sticky-mobile-cta');
  if (stickyEl) {
    let visible = false;
    const onScroll = () => {
      const shouldShow = window.scrollY > 600;
      if (shouldShow !== visible) {
        visible = shouldShow;
        stickyEl.style.transform = shouldShow ? 'translateY(0)' : 'translateY(100%)';
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
