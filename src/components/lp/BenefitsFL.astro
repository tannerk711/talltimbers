---
const benefits = [
  {
    title: 'A Specialist Who Walks You Through It',
    body: "John talks through your deal first, then runs the file. You get a real conversation about what works, what's risky, and what the lender will want, not a callback with a yes or no after you've already signed a contract.",
    iconPath: 'M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z',
  },
  {
    title: 'Typical FL Close: 21-30 Days',
    body: "Most Florida DSCR closes in John's network land in 21-30 days on clean files, faster when condo questionnaires and title come back quickly. Realistic timelines you can plan around, not a marketing promise that slips at week 3.",
    iconPath: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Scale Past the Fannie 10-Loan Cap',
    body: "DSCR doesn't count against your conventional limits. 11th, 15th, 30th door, same process. Built for portfolio scale.",
    iconPath: 'M3 12l2-2 4 4 8-8 4 4M3 21h18',
  },
];
---

<section data-fl-section="benefits" class="bg-white py-20 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {benefits.map((b) => (
        <div class="flex flex-col items-start rounded-2xl border border-gray-100 bg-white p-7 md:p-8 card-soft-shadow hover:shadow-lg transition-shadow">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue/10 text-blue mb-5">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={b.iconPath} />
            </svg>
          </div>
          <h3 class="text-lg md:text-xl font-bold text-navy">{b.title}</h3>
          <p class="mt-3 text-sm md:text-[15px] leading-relaxed text-gray-500">{b.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
