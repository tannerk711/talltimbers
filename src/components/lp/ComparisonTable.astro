---
const rows = [
  { feature: 'Pre-runs FL insurance quotes before underwriting', us: 'yes', generic: 'no', bank: 'no' },
  { feature: 'Funds non-warrantable FL condos', us: 'yes', generic: 'maybe', bank: 'no' },
  { feature: 'Verifies STR zoning before submit', us: 'yes', generic: 'no', bank: 'na' },
  { feature: 'Accepts AirDNA for STR income', us: 'yes', generic: 'maybe', bank: 'no' },
  { feature: 'Tax returns required', us: 'no', generic: 'no', bank: 'yes' },
  { feature: 'Closes in 14-21 days', us: 'yes', generic: 'maybe', bank: 'no' },
  { feature: 'Lender options on your deal', us: '50+', generic: 'Single program', bank: 'Single program' },
];

function renderCell(value: string) {
  if (value === 'yes') {
    return { class: 'text-green', label: '✓' };
  }
  if (value === 'no') {
    return { class: 'text-red-400', label: '✗' };
  }
  if (value === 'maybe') {
    return { class: 'text-amber', label: '~' };
  }
  if (value === 'na') {
    return { class: 'text-gray-300', label: 'N/A' };
  }
  return { class: 'text-navy font-bold', label: value };
}
---

<section class="bg-off-white py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <p class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">SPECIALIST NETWORK VS. THE REST</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-navy">Why a FL Specialist Beats Going Direct</h2>
      <p class="mt-4 text-lg text-gray-500 leading-relaxed max-w-3xl mx-auto">
        Most generic DSCR lenders quote one rate from one program. Big banks need W-2s. The specialist network beats both, particularly on the FL-specific stuff that kills deals at underwriting.
      </p>
    </div>

    <!-- Table, desktop -->
    <div class="hidden md:block rounded-xl border border-gray-200 bg-white overflow-hidden shadow-sm">
      <div class="grid grid-cols-[2fr_1fr_1fr_1fr] bg-navy text-white text-sm font-semibold">
        <div class="px-5 py-4">Capability</div>
        <div class="px-5 py-4 text-center bg-blue/20 border-l border-white/10">FL Specialist Network</div>
        <div class="px-5 py-4 text-center border-l border-white/10">Generic DSCR Lender</div>
        <div class="px-5 py-4 text-center border-l border-white/10">Big-Bank Mortgage</div>
      </div>

      {rows.map((row, i) => {
        const us = renderCell(row.us);
        const generic = renderCell(row.generic);
        const bank = renderCell(row.bank);
        return (
          <div class={`grid grid-cols-[2fr_1fr_1fr_1fr] text-sm ${i % 2 === 0 ? 'bg-white' : 'bg-off-white'} border-t border-gray-100`}>
            <div class="px-5 py-4 text-navy font-medium">{row.feature}</div>
            <div class={`px-5 py-4 text-center bg-blue/[0.04] border-l border-gray-100 ${us.class} text-lg font-bold`}>{us.label}</div>
            <div class={`px-5 py-4 text-center border-l border-gray-100 ${generic.class} text-lg font-bold`}>{generic.label}</div>
            <div class={`px-5 py-4 text-center border-l border-gray-100 ${bank.class} text-lg font-bold`}>{bank.label}</div>
          </div>
        );
      })}
    </div>

    <!-- Stacked mobile version -->
    <div class="md:hidden space-y-4">
      {rows.map((row) => {
        const us = renderCell(row.us);
        const generic = renderCell(row.generic);
        const bank = renderCell(row.bank);
        return (
          <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <p class="text-sm font-semibold text-navy mb-3">{row.feature}</p>
            <div class="grid grid-cols-3 gap-2 text-center text-xs">
              <div class="rounded-lg bg-blue/[0.06] py-2">
                <div class={`text-lg font-bold ${us.class}`}>{us.label}</div>
                <div class="text-[10px] uppercase tracking-wider text-gray-500 mt-1">FL Specialist</div>
              </div>
              <div class="rounded-lg bg-gray-50 py-2">
                <div class={`text-lg font-bold ${generic.class}`}>{generic.label}</div>
                <div class="text-[10px] uppercase tracking-wider text-gray-500 mt-1">Generic DSCR</div>
              </div>
              <div class="rounded-lg bg-gray-50 py-2">
                <div class={`text-lg font-bold ${bank.class}`}>{bank.label}</div>
                <div class="text-[10px] uppercase tracking-wider text-gray-500 mt-1">Big Bank</div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Legend + CTA -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-xs text-gray-500">
      <span class="flex items-center gap-1.5"><span class="text-green text-base font-bold">✓</span> Standard</span>
      <span class="flex items-center gap-1.5"><span class="text-amber text-base font-bold">~</span> Sometimes</span>
      <span class="flex items-center gap-1.5"><span class="text-red-400 text-base font-bold">✗</span> Not offered</span>
    </div>
  </div>
</section>
