---
const currentYear = new Date().getFullYear();
---

<footer class="footer-black py-14 px-4 sm:px-6 border-t border-white/[0.06]">
  <div class="max-w-5xl mx-auto">
    <!-- Brand row -->
    <div class="flex items-center gap-2.5 mb-8">
      <svg class="h-7 w-7" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M16 30V14" stroke="#3FC793" stroke-width="2.4" stroke-linecap="round"/>
        <ellipse cx="11.2" cy="11" rx="4.3" ry="6" transform="rotate(-32 11.2 11)" fill="#3FC793"/>
        <ellipse cx="20.6" cy="9.8" rx="4.6" ry="6.4" transform="rotate(28 20.6 9.8)" fill="#1E9E6E"/>
        <ellipse cx="22.4" cy="17.6" rx="3.5" ry="5" transform="rotate(54 22.4 17.6)" fill="#3FC793"/>
        <ellipse cx="14.3" cy="5.4" rx="3.3" ry="4.6" transform="rotate(-8 14.3 5.4)" fill="#1E9E6E"/>
      </svg>
      <span class="text-base font-bold text-white tracking-tight">Tall<span class="text-blue-light">Timbers</span> <span class="text-white/40 font-normal text-sm">Realty and Financial Services</span></span>
    </div>

    <!-- Compliance block -->
    <div class="text-white/40 text-xs leading-relaxed space-y-3">
      <p>
        <strong class="text-white/70">Tall Timbers Realty and Financial Services connects Georgia real estate investors with DSCR loan financing.</strong> This is not a commitment to lend. Licensed mortgage activity, including pre-qualification, pre-approval, file structuring, lender selection, rate quotes, credit pulls, and income verification, is performed by Adam C. Cunningham, Mortgage Loan Originator, NMLS #312817, and the lender partners in his network.
      </p>
      <p>
        Equal Housing Opportunity. All loan products are offered through licensed mortgage originators and their lender partners. Loan terms, eligibility, and approval are subject to underwriting review and the originating lender's program requirements. Property types, locations, and borrower scenarios may not qualify under all programs.
      </p>
      <p>
        By submitting your information, you consent to be contacted by Tall Timbers Realty and Financial Services via phone, SMS, or email regarding your inquiry, even if your number is on a Do Not Call list. Consent is not a condition of any loan or service. Message and data rates may apply.
      </p>
    </div>

    <!-- Links + EHO -->
    <div class="mt-8 pt-6 border-t border-white/5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4 text-xs text-white/30">
        <a href="/privacy-policy/" class="hover:text-white/60 transition-colors">Privacy Policy</a>
        <span>|</span>
        <a href="/terms-of-service/" class="hover:text-white/60 transition-colors">Terms of Service</a>
        <span>|</span>
        <span>© {currentYear} Tall Timbers Realty and Financial Services</span>
      </div>

      <div class="flex items-center gap-3">
        <span class="text-xs text-white/40 font-medium">Equal Housing Opportunity</span>
        <svg class="h-7 w-7 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h12a1 1 0 001-1V10" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 21V13h6v8" />
        </svg>
      </div>
    </div>
  </div>
</footer>
