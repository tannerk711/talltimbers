---
interface Props {
  phoneNumber?: string;
}

const { phoneNumber = '(855) 738-1557' } = Astro.props;
const phoneHref = `tel:${phoneNumber.replace(/\D/g, '')}`;
---

<section data-fl-section="final-cta" class="relative bg-navy py-20 md:py-24 overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/sections/fl-final-cta.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true" loading="lazy" decoding="async" />
    <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(11,17,32,0.78) 0%, rgba(11,17,32,0.55) 100%);"></div>
  </div>
  <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
      Ready to Talk Through Your Florida Deal?
    </h2>
    <p class="mt-4 text-lg leading-relaxed text-slate-300 max-w-2xl mx-auto">
      Check your eligibility in 60 seconds. John or a licensed member of his team reaches out the same business day to walk through your scenario. No SSN. No hard credit pull. No obligation.
    </p>

    <div class="mt-8 flex flex-col items-center gap-3 sm:gap-4 sm:flex-row sm:justify-center">
      <a
        href="#lead-form"
        data-event="scroll_to_form"
        data-location="final_cta"
        class="inline-flex items-center justify-center rounded-lg bg-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-dark w-full sm:w-auto"
      >
        Match Me With My FL Specialist
        <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href={phoneHref}
        data-event="phone_click"
        data-location="final_cta"
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-500 px-6 py-3 text-base font-medium text-slate-300 transition-colors hover:border-white hover:text-white w-full sm:w-auto"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-1.86.93a11 11 0 005.2 5.2l.93-1.86a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z" />
        </svg>
        Call {phoneNumber}
      </a>
    </div>

    <div data-fl-finalcta-chips class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <span class="fl-reveal-chip chip chip-on-dark-soft text-sm">
        <svg class="h-4 w-4 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        No hard credit pull
      </span>
      <span class="fl-reveal-chip chip chip-on-dark-soft text-sm">
        <svg class="h-4 w-4 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        No obligation
      </span>
      <span class="fl-reveal-chip chip chip-on-dark-soft text-sm">
        <svg class="h-4 w-4 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        $0 upfront fees
      </span>
    </div>
  </div>
</section>
