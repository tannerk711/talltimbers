---
const pillars = [
  {
    label: 'Insurance',
    title: 'The Real Florida Deal-Killer',
    body: 'FL homeowner premiums on investment SFRs run $250-$500+/month. The wrong carrier or a missing 4-point/wind-mit doc tanks your DSCR ratio at underwriting. Your matched specialist pulls multiple FL carrier quotes and confirms wind-mitigation credits before submitting your file.',
    iconPath: 'M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z',
    accent: 'amber',
  },
  {
    label: 'Condo Warrantability',
    title: 'Non-Warrantable Condos After Surfside',
    body: 'After HB 913 and the post-2025 Fannie/Freddie guideline updates, large numbers of older FL condos can\'t be financed conventionally. DSCR/Non-QM is frequently the only path. Your matched specialist routes non-warrantable condo deals to the lenders in our network that fund them at up to 70% LTV.',
    iconPath: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2m-2 0h-3m-1 0v-4a1 1 0 00-1-1h-2a1 1 0 00-1 1v4m4 0h-4m-6 0h2v-4a1 1 0 011-1h2a1 1 0 011 1v4',
    accent: 'blue',
  },
  {
    label: 'STR Zoning',
    title: 'Orange County vs. Osceola County',
    body: 'Disney-area STR buyers get crushed when their dream Airbnb sits in a zone that prohibits short-term rentals. Orange County (Orlando proper) prohibits STRs in most residential zones. Osceola (Kissimmee, Four Corners, Davenport) permits them. Your matched specialist verifies zoning before you waste 30 days under contract.',
    iconPath: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z',
    accent: 'green',
  },
  {
    label: 'Property Tax',
    title: 'Post-Sale Reassessment Shock',
    body: 'FL investment properties have NO Save Our Homes cap and NO homestead exemption. The day you close, the property gets reassessed at full market value, so your DSCR projection from listing-era taxes is wrong. Your matched specialist underwrites against post-reassessment numbers, not the seller\'s tax bill.',
    iconPath: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    accent: 'amber',
  },
];

const accentClasses: Record<string, string> = {
  amber: 'bg-amber/10 text-amber',
  blue: 'bg-blue/10 text-blue',
  green: 'bg-green/10 text-green',
};
---

<section id="fl-underwriting" class="bg-off-white py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <p class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">FLORIDA UNDERWRITING REALITY</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-navy">What Generic DSCR Lenders Miss About Florida Deals</h2>
      <p class="mt-4 text-lg text-gray-500 leading-relaxed">
        Four FL-specific landmines that kill deals at the closing table. Your matched Florida specialist pre-runs all four before your file ever gets submitted.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
      {pillars.map((p) => (
        <div class="rounded-xl border border-gray-200 bg-white p-6 md:p-7 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-start gap-4">
            <div class={`flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg ${accentClasses[p.accent]}`}>
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={p.iconPath} />
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-[11px] uppercase tracking-wider text-gray-400 font-semibold">{p.label}</p>
              <h3 class="text-lg md:text-xl font-bold text-navy mt-1">{p.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{p.body}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing line + CTA -->
    <div class="mt-10 text-center">
      <a
        href="#lead-form"
        data-event="scroll_to_form"
        data-location="fl_underwriting"
        class="inline-flex items-center rounded-lg bg-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        Get My Florida Deal Reviewed
        <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
