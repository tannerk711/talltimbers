---
const pillars = [
  {
    label: 'Condo Warrantability',
    title: 'Non-Warrantable Condos After Surfside',
    body: "After SB 4-D (2022) and SB 154 (2023), Florida condos face structural integrity reserve studies and milestone inspections that have pushed a lot of older buildings into non-warrantable territory. Conventional financing dies on those. John knows which lenders in his network fund non-warrantable FL condos under DSCR/Non-QM, usually up to 70% LTV, and which buildings are flat dead even on Non-QM. You'll know which bucket your condo is in before you write an offer.",
    iconPath: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2m-2 0h-3m-1 0v-4a1 1 0 00-1-1h-2a1 1 0 00-1 1v4m4 0h-4m-6 0h2v-4a1 1 0 011-1h2a1 1 0 011 1v4',
    accent: 'blue',
    image: '/images/sections/fl-pillar-condos.jpg',
  },
  {
    label: 'STR Zoning',
    title: 'Orange County vs. Osceola County',
    body: "Disney-area STR buyers get crushed when their dream Airbnb sits in a zone that prohibits short-term rentals. Orange County (Orlando proper) prohibits STRs in most residential zones. Osceola (Kissimmee, Four Corners, Davenport) permits them. Destin and 30A have permit-zoned STR districts. John tells you up front what to verify with the county before you waste 30 days under contract, and which lenders will accept AirDNA on a permitted property.",
    iconPath: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z',
    accent: 'green',
    image: '/images/sections/fl-pillar-str.jpg',
  },
  {
    label: 'Hurricane & Flood Zones',
    title: 'Coastal Exposure Isn\'t a Dealbreaker',
    body: "Half of FL inventory is in some kind of wind or flood zone, AE, VE, or post-Ian rebuild markets. Most generic DSCR lenders just decline or cap LTV hard. John knows which lenders in his network fund FL coastal exposure and how each one treats elevation certificates, flood zone X vs. AE, and Ian-affected properties. The coverage exists, you just have to be at the right lender.",
    iconPath: 'M3 13a4 4 0 014-4h10a4 4 0 014 4M5 19a2 2 0 002-2v-2H5a2 2 0 00-2 2v0a2 2 0 002 2zm14 0a2 2 0 01-2-2v-2h2a2 2 0 012 2v0a2 2 0 01-2 2z',
    accent: 'amber',
    image: '/images/sections/fl-pillar-coastal.jpg',
  },
  {
    label: 'Property Tax',
    title: 'Post-Sale Reassessment Shock',
    body: "FL investment properties have NO Save Our Homes cap and NO homestead exemption. After the sale, the property gets reassessed at full market value (the bump typically hits year two on the new tax roll), so your DSCR projection based on the seller's tax bill is wrong. John underwrites against post-reassessment numbers so the deal doesn't pencil great on paper and tank in year two.",
    iconPath: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    accent: 'amber',
    image: '/images/sections/fl-pillar-tax.jpg',
  },
];

const accentClasses: Record<string, string> = {
  amber: 'bg-amber/15 text-amber',
  blue: 'bg-blue/15 text-blue-light',
  green: 'bg-green/15 text-green',
};
---

<section id="fl-underwriting" data-fl-section="underwriting" class="bg-off-white py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <p class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">FLORIDA UNDERWRITING REALITY</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-navy">What Generic DSCR Lenders Miss About Florida Deals</h2>
      <p class="mt-4 text-lg text-gray-500 leading-relaxed">
        Four FL-specific issues that kill deals at the closing table. John walks you through each one on the first call so you know what you're working with before you write an offer.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-7">
      {pillars.map((p) => (
        <div class="rounded-xl overflow-hidden bg-white card-soft-shadow transition-shadow hover:shadow-lg">
          <!-- Photo top with overlay label/title bar -->
          <div class="relative aspect-[4/3] w-full overflow-hidden">
            <img
              src={p.image}
              alt={p.title}
              class="absolute inset-0 h-full w-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-x-0 bottom-0 pillar-photo-bar px-5 md:px-6 py-4">
              <div class="flex items-center gap-3">
                <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg ${accentClasses[p.accent]}`}>
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={p.iconPath} />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-[10px] uppercase tracking-[0.1em] text-white/60 font-semibold">{p.label}</p>
                  <h3 class="text-base md:text-lg font-bold text-white truncate">{p.title}</h3>
                </div>
              </div>
            </div>
          </div>
          <!-- Body copy on white -->
          <div class="px-6 md:px-7 py-6 md:py-7">
            <p class="text-sm leading-relaxed text-gray-600">{p.body}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing line + CTA -->
    <div class="mt-10 text-center">
      <a
        href="#lead-form"
        data-event="scroll_to_form"
        data-location="fl_underwriting"
        class="inline-flex items-center rounded-lg bg-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-dark"
      >
        Get My Florida Deal Reviewed
        <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
