---
import DSCRForm from '../form/DSCRForm';


interface Props {
  h1?: string;
  formHeadline?: string;
  formSubhead?: string;
}

const {
  h1 = 'Florida DSCR Loans. Qualify on Rents, Not Tax Returns.',
  formHeadline = "Check your eligibility",
  formSubhead = '60 seconds. No SSN. No credit pull.',
} = Astro.props;
---

<section id="lead-form" data-fl-section="hero" class="relative overflow-hidden">
  <!-- Full-bleed FL waterfront photo with a centered forest-green gradient mask so single-column content remains legible -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      id="fl-hero-bg"
      src="/images/sections/florida-hero.jpg"
      alt=""
      class="fl-hero-bg absolute inset-0 w-full h-[120%] object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(7,38,15,0.78) 0%, rgba(7,38,15,0.70) 50%, rgba(7,38,15,0.85) 100%);"></div>
    <!-- Soft brand-accent blobs for depth -->
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(30,158,110,0.14) 0%, transparent 70%);"></div>
    <div class="absolute -bottom-40 -left-40 w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(200,147,44,0.06) 0%, transparent 70%);"></div>
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 lg:py-24">
    <div class="text-center">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 rounded-full border border-blue/30 bg-blue/10 px-3 py-1 mb-6">
        <span class="text-[10px] uppercase tracking-[0.15em] font-semibold text-blue-light">DSCR Investor Loans</span>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold text-white tracking-tight leading-[1.05]">
        {h1}
      </h1>
    </div>

    <!-- Form widget under the headline -->
    <div class="mt-10 md:mt-12">
      <div class="rounded-xl bg-navy/95 border border-white/15 backdrop-blur-md p-5 sm:p-6 md:p-7 shadow-2xl ring-1 ring-black/20">
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-1 text-center">{formHeadline}</h2>
        <p class="text-xs sm:text-sm text-white/75 mb-5 text-center">{formSubhead}</p>
        <DSCRForm client:load />
      </div>

      <!-- Sub-form trust row -->
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs sm:text-sm text-white/75">
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          No Credit Pull
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-blue-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Eligibility in 60 Sec
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-blue-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Specialist Match
        </span>
      </div>
    </div>
  </div>
</section>
