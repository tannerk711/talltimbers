---
import DSCRForm from '../form/DSCRForm';
import SpecialistCard from './SpecialistCard.astro';

interface Props {
  h1?: string;
  subhead?: string;
  formHeadline?: string;
  formSubhead?: string;
}

const {
  h1 = 'Florida DSCR Loans. Qualify on Rents, Not Tax Returns.',
  subhead = "Get matched with John Peisner at Barrett Financial Group, a Florida DSCR specialist with 500+ closed loans. John walks you through the deal, flags the FL-specific issues other lenders miss, and matches your file to the right lender. Consultative from the first call. No surprises at the closing table.",
  formHeadline = "Check your Florida deal's eligibility",
  formSubhead = '60 seconds. No SSN. No hard credit pull.',
} = Astro.props;
---

<section id="lead-form" data-fl-section="hero" class="relative overflow-hidden">
  <!-- Full-bleed FL waterfront photo, asymmetric navy gradient mask so left-column copy + right-column form remain legible -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      id="fl-hero-bg"
      src="/images/sections/fl-hero.jpg"
      alt=""
      class="fl-hero-bg absolute inset-0 w-full h-[120%] object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(11,17,32,0.85) 0%, rgba(11,17,32,0.55) 55%, rgba(11,17,32,0.30) 100%);"></div>
    <!-- Soft brand-accent blobs for depth -->
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.10) 0%, transparent 70%);"></div>
    <div class="absolute -bottom-40 -left-40 w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(212,147,13,0.06) 0%, transparent 70%);"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14 lg:py-16">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-8 lg:gap-12 items-start">
      <!-- LEFT: H1 + subhead + trust + secondary -->
      <div>
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 rounded-full border border-blue/30 bg-blue/10 px-3 py-1 mb-5">
          <span class="text-[10px] uppercase tracking-[0.15em] font-semibold text-blue-light">Florida DSCR Specialist</span>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold text-white tracking-tight leading-[1.05]">
          {h1}
        </h1>

        <p class="mt-5 text-base sm:text-lg text-white/70 leading-relaxed max-w-2xl">
          {subhead}
        </p>

        <!-- Trust micro-bar (chip pills) -->
        <div data-fl-hero-chips class="mt-7 flex flex-wrap gap-x-3 gap-y-3 text-sm">
          <span class="fl-reveal-chip chip chip-dark text-white/90">
            <span class="flex gap-0.5">
              {[...Array(5)].map(() => (
                <svg class="h-3.5 w-3.5 text-amber" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </span>
            <span class="font-semibold">4.9/5</span>
            <span class="font-medium text-white/75">for John Peisner / Barrett Financial</span>
          </span>
          <span class="fl-reveal-chip chip chip-dark text-white/90">
            <svg class="h-3.5 w-3.5 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="font-semibold">500+ DSCR Loans Closed</span>
          </span>
          <span class="fl-reveal-chip chip chip-dark text-white/90">
            <svg class="h-3.5 w-3.5 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="font-semibold">$0 Upfront Fees</span>
          </span>
        </div>

        <!-- Specialist mini-card (under hero copy on desktop, hides on mobile to keep form ATF) -->
        <div class="mt-8 hidden lg:block max-w-md">
          <SpecialistCard variant="compact" theme="dark" />
        </div>
      </div>

      <!-- RIGHT: Form widget -->
      <div class="lg:sticky lg:top-24">
        <div class="rounded-xl bg-navy/95 border border-white/15 backdrop-blur-md p-5 sm:p-6 shadow-2xl ring-1 ring-black/20">
          <h2 class="text-xl sm:text-2xl font-bold text-white mb-1">{formHeadline}</h2>
          <p class="text-xs sm:text-sm text-white/75 mb-5">{formSubhead}</p>
          <DSCRForm client:load />
        </div>

        <!-- Mobile-only specialist card under form -->
        <div class="mt-4 lg:hidden">
          <SpecialistCard variant="compact" theme="dark" />
        </div>

        <!-- Sub-form trust row -->
        <div class="mt-4 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs text-white/75">
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Soft Pull Only
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-blue-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Eligibility in 60 Sec
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-blue-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            FL Specialist Match
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
