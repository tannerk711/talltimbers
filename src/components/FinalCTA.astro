---

---

<section id="final-cta" class="relative bg-navy py-16 md:py-24 overflow-hidden">
  <!-- Background image with dark overlay -->
  <div class="absolute inset-0">
    <img src="/images/sections/final-cta.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true" />
    <div class="absolute inset-0 bg-[#0B1120]/75" />
  </div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 data-gsap="heading" class="text-3xl font-bold tracking-tight text-white md:text-4xl">
        Your Next Rental Property Deserves a Specialist
      </h2>
      <p data-gsap="subhead" class="mt-4 text-lg leading-relaxed text-slate-300">
        One form. A licensed DSCR specialist who structures your deal for approval. Soft pull only. Match in 2 minutes, close in as few as 21 days.
      </p>

      <div data-gsap="cta" class="mt-8 flex flex-col items-center gap-3 sm:gap-4 sm:flex-row sm:justify-center">
        <a
          href="/qualify/"
          class="inline-flex items-center rounded-lg bg-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-dark"
        >
          Match Me With a Specialist
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/calculator/"
          class="inline-flex items-center rounded-lg border border-slate-500 px-6 py-3 text-base font-medium text-slate-300 transition-colors hover:border-white hover:text-white"
        >
          Calculate My DSCR
        </a>
      </div>

      <!-- Trust signals -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3 sm:gap-6">
        <span class="flex items-center gap-2 text-sm text-slate-400">
          <svg class="h-4 w-4 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          No hard credit pull
        </span>
        <span class="flex items-center gap-2 text-sm text-slate-400">
          <svg class="h-4 w-4 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          No obligation
        </span>
        <span class="flex items-center gap-2 text-sm text-slate-400">
          <svg class="h-4 w-4 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Free to use
        </span>
      </div>
    </div>
  </div>
</section>
