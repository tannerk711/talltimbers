---
import BaseLayout from './BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion';

interface Stat {
  value: string;
  label: string;
}

interface QualifyItem {
  text: string;
}

interface DealDetail {
  label: string;
  value: string;
  highlight?: boolean;
}

interface DealBreakdown {
  label: string;
  value: string;
  highlight?: boolean;
}

interface CompareRow {
  feature: string;
  values: string[];
}

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  /* SEO */
  title: string;
  description: string;
  slug: string;
  /* Hero */
  programName: string;
  h1: string;
  subhead: string;
  stats: Stat[];
  heroImage?: string;
  /* How It Works */
  howItWorks: string[];
  inlineCallout?: string;
  /* Requirements */
  qualifyItems: QualifyItem[];
  notRightItems: QualifyItem[];
  /* Deal Example */
  dealInvestor: string;
  dealProperty: string;
  dealDetails: DealDetail[];
  dealBreakdown: DealBreakdown[];
  dealDscr: string;
  dealDscrColor: string;
  dealCashFlow: string;
  dealCashFlowPositive: boolean;
  dealCloseTime: string;
  dealMathLine: string;
  dealQuote: string;
  dealQuoteAttribution: string;
  dealNote?: string;
  /* Specialist Structuring (replaces former Rate Table) */
  structuringTitle?: string;
  structuringIntro?: string;
  structuringScenarios?: { headline: string; detail: string }[];
  structuringNote?: string;
  /* Legacy props. Silently accepted from existing program pages so they don't break.
     These are no longer rendered. Remove the props from individual program pages over time. */
  rateTableHeaders?: string[];
  rateTableRows?: { fico: string; rates: string[] }[];
  rateTableNote?: string;
  /* Comparison */
  comparePrograms: string[];
  compareRows: CompareRow[];
  compareLinks: { label: string; href: string }[];
  /* FAQ */
  faqItems: FAQItem[];
  /* CTA */
  ctaCopy: string;
  /* JSON-LD */
  jsonLd: object;
}

const {
  title,
  description,
  slug,
  programName,
  h1,
  subhead,
  stats,
  heroImage,
  howItWorks,
  inlineCallout,
  qualifyItems,
  notRightItems,
  dealInvestor,
  dealProperty,
  dealDetails,
  dealBreakdown,
  dealDscr,
  dealDscrColor,
  dealCashFlow,
  dealCashFlowPositive,
  dealCloseTime,
  dealMathLine,
  dealQuote,
  dealQuoteAttribution,
  dealNote,
  structuringIntro,
  structuringScenarios,
  structuringNote,
  comparePrograms,
  compareRows,
  compareLinks,
  faqItems,
  ctaCopy,
  jsonLd,
} = Astro.props;

const canonical = `https://dscrbroker.com/programs/${slug}`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>

  <!-- Section 1: Hero (Dark with background image) -->
  <section class="relative bg-[#0B1120] pt-16 pb-20 md:pt-16 md:pb-20 overflow-hidden">
    {heroImage && (
      <div class="absolute inset-0">
        <img src={heroImage} alt="" class="w-full h-full object-cover" aria-hidden="true" />
        <div class="absolute inset-0 bg-[#0B1120]/80 backdrop-blur-[2px]" />
      </div>
    )}
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="text-sm text-slate-400">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li class="text-slate-500">/</li>
          <li><a href="/programs" class="hover:text-white transition-colors">Loan Programs</a></li>
          <li class="text-slate-500">/</li>
          <li class="text-white">{programName} Loans</li>
        </ol>
      </nav>

      <!-- H1 -->
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mt-6">
        {h1}
      </h1>

      <!-- Subhead -->
      <p class="text-lg text-slate-300 max-w-3xl mt-4 leading-relaxed">
        {subhead}
      </p>

      <!-- Key Stats Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mt-8 md:mt-10">
        {stats.map((stat) => (
          <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-5 py-4 text-center">
            <div class="text-2xl font-bold text-white">{stat.value}</div>
            <div class="text-xs text-slate-400 uppercase tracking-wider mt-1 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- CTA Button -->
      <a
        href={`/qualify/?program=${slug}`}
        class="inline-block mt-8 bg-blue-500 hover:bg-blue-600 text-white font-semibold text-sm uppercase tracking-wider px-8 py-4 rounded transition-colors"
      >
        Match Me With a {programName} Specialist
      </a>
    </div>
  </section>

  <!-- Section 2: How This Program Works (Light, Off-White) -->
  <section class="bg-[#F8F6F1] py-16 md:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 mb-3">HOW IT WORKS</p>
      <h2 class="text-3xl font-bold text-[#0B1120] mb-6">How {programName} Loans Work</h2>
      <div class="text-base text-slate-600 leading-relaxed space-y-4">
        {howItWorks.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      {inlineCallout && (
        <div class="bg-white border border-[#E8E4DD] rounded-lg p-6 my-8 text-center">
          <p class="text-lg font-semibold text-[#0B1120]">{inlineCallout}</p>
        </div>
      )}
    </div>
  </section>

  <!-- Section 3: Requirements (Light, White) -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 mb-3">REQUIREMENTS</p>
      <h2 class="text-3xl font-bold text-[#0B1120] mb-8">Do You Qualify for a {programName} Loan?</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- You Qualify If -->
        <div>
          <div class="flex items-center gap-2 mb-4">
            <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h3 class="text-lg font-semibold text-[#0B1120]">You Qualify If</h3>
          </div>
          <ul class="space-y-0">
            {qualifyItems.map((item) => (
              <li class="flex items-start gap-3 text-slate-700 text-sm leading-relaxed py-2">
                <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span>{item.text}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- This May Not Be Right If -->
        <div>
          <div class="flex items-center gap-2 mb-4">
            <div class="w-6 h-6 rounded-full bg-amber-100 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </div>
            <h3 class="text-lg font-semibold text-[#0B1120]">This May Not Be Right If</h3>
          </div>
          <ul class="space-y-0">
            {notRightItems.map((item) => (
              <li class="flex items-start gap-3 text-slate-700 text-sm leading-relaxed py-2">
                <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                <span>{item.text}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <p class="text-sm text-slate-500 mt-8 text-center">
        Not sure? A <a href={`/qualify/?program=${slug}`} class="text-blue-500 hover:text-blue-600 underline">specialist</a> can review your specific scenario.
      </p>
    </div>
  </section>

  <!-- Section 4: Deal Example (Light, Off-White) -->
  <section class="bg-[#F8F6F1] py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 mb-3">DEAL EXAMPLE</p>
      <h2 class="text-3xl font-bold text-[#0B1120] mb-8">Real {programName} Deal</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Left: Property Details -->
        <div class="bg-white border border-[#E8E4DD] rounded-lg p-6">
          <p class="text-sm font-semibold text-[#0B1120]">{dealInvestor}</p>
          <p class="text-sm text-slate-500 mt-1">{dealProperty}</p>
          <span class="inline-block bg-blue-50 text-blue-600 text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded mt-2">
            {programName}
          </span>
          <div class="mt-4 space-y-0">
            {dealDetails.map((detail) => (
              <div class={`flex justify-between py-2 border-b border-[#F0EDE8] last:border-0 ${detail.highlight ? 'font-semibold' : ''}`}>
                <span class="text-sm text-slate-500">{detail.label}</span>
                <span class={`text-sm font-semibold text-[#0B1120]`}>{detail.value}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Financial Breakdown -->
        <div class="bg-white border border-[#E8E4DD] rounded-lg p-6">
          <div class="space-y-0">
            {dealBreakdown.map((item) => (
              <div class={`flex justify-between py-2 border-b border-[#F0EDE8] last:border-0 ${item.highlight ? 'font-semibold' : ''}`}>
                <span class="text-sm text-slate-500">{item.label}</span>
                <span class="text-sm font-semibold text-[#0B1120]">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-6 pt-4 border-t border-[#E8E4DD]">
            <div class="text-center">
              <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">DSCR Ratio</div>
              <div class={`text-3xl font-bold ${dealDscrColor}`}>{dealDscr}</div>
            </div>
            <div class="flex justify-between mt-4">
              <div>
                <div class="text-xs text-slate-500">Monthly Cash Flow</div>
                <div class={`text-sm font-semibold ${dealCashFlowPositive ? 'text-emerald-600' : 'text-amber-600'}`}>{dealCashFlow}</div>
              </div>
              <div class="text-right">
                <div class="text-xs text-slate-500">Close Time</div>
                <div class="text-sm font-semibold text-[#0B1120]">{dealCloseTime}</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- DSCR Math Line -->
      <div class="bg-white border border-[#E8E4DD] rounded-lg px-6 py-4 mt-6 text-center text-sm text-slate-600 font-mono">
        {dealMathLine}
      </div>

      {dealNote && (
        <p class="text-sm text-slate-500 mt-4 italic">{dealNote}</p>
      )}

      <!-- Investor Quote -->
      <blockquote class="border-l-4 border-blue-500 pl-4 mt-6 text-slate-600 italic text-sm">
        "{dealQuote}"
      </blockquote>
      <p class="text-xs text-slate-400 mt-2 pl-4">{dealQuoteAttribution}</p>
      <p class="text-[10px] text-slate-400 mt-1 pl-4">Results may vary. This is a representative example, not a guarantee of future performance.</p>
    </div>
  </section>

  <!-- Section 5: Specialist Structuring (Light, White) -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 mb-3">SPECIALIST STRUCTURING</p>
      <h2 class="text-3xl font-bold text-[#0B1120] mb-4">How a Specialist Structures a {programName} Deal</h2>
      <p class="text-base text-slate-600 leading-relaxed mb-8">
        {structuringIntro || `${programName} programs vary widely between lenders. Overlays, exception tolerance, and program guidelines shift constantly. Your matched specialist's job is not to send you a rate sheet. It's to structure your file for the lender most likely to approve it. Here's what that looks like in practice.`}
      </p>

      {structuringScenarios && structuringScenarios.length > 0 ? (
        <div class="grid gap-4 md:grid-cols-2">
          {structuringScenarios.map((s) => (
            <div class="bg-[#F8F6F1] border border-[#E8E4DD] rounded-xl p-5">
              <h3 class="text-sm font-bold text-[#0B1120] mb-2">{s.headline}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{s.detail}</p>
            </div>
          ))}
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2">
          <div class="bg-[#F8F6F1] border border-[#E8E4DD] rounded-xl p-5">
            <h3 class="text-sm font-bold text-[#0B1120] mb-2">Lender Overlay Mapping</h3>
            <p class="text-sm text-slate-600 leading-relaxed">Every {programName} lender has different overlays: credit minimums, reserves, property condition rules, and exception tolerance. Your specialist knows which lenders' overlays match your scenario.</p>
          </div>
          <div class="bg-[#F8F6F1] border border-[#E8E4DD] rounded-xl p-5">
            <h3 class="text-sm font-bold text-[#0B1120] mb-2">File Presentation</h3>
            <p class="text-sm text-slate-600 leading-relaxed">How a file is presented to an underwriter often determines approval. Your specialist frames the narrative (compensating factors, rent comps, reserves) to give your file the best chance.</p>
          </div>
          <div class="bg-[#F8F6F1] border border-[#E8E4DD] rounded-xl p-5">
            <h3 class="text-sm font-bold text-[#0B1120] mb-2">Exception Hunting</h3>
            <p class="text-sm text-slate-600 leading-relaxed">When an automated decision says no, the specialist asks why and what would change it. That's the difference between losing a deal and saving it.</p>
          </div>
          <div class="bg-[#F8F6F1] border border-[#E8E4DD] rounded-xl p-5">
            <h3 class="text-sm font-bold text-[#0B1120] mb-2">Pivot When Needed</h3>
            <p class="text-sm text-slate-600 leading-relaxed">If the first lender declines, your specialist pivots to a second within 48 hours, not weeks. The 50+ lender network exists to keep deals moving when one path closes.</p>
          </div>
        </div>
      )}

      {structuringNote && (
        <p class="text-sm text-slate-500 mt-6">{structuringNote}</p>
      )}

      <p class="text-xs text-slate-400 mt-8 max-w-3xl">
        Loan terms and approval are subject to your specialist's review, full underwriting, appraisal, and the matched lender's specific guidelines. This is not a loan offer or commitment to lend.
      </p>
    </div>
  </section>

  <!-- Section 6: Comparison (Light, Off-White) -->
  <section class="bg-[#F8F6F1] py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 mb-3">COMPARE</p>
      <h2 class="text-3xl font-bold text-[#0B1120] mb-8">How {programName} Compares</h2>

      <div class="overflow-x-auto -mx-4 sm:mx-0">
        <table class="w-full border-collapse min-w-[500px]">
          <thead>
            <tr class="bg-white">
              <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-left">Feature</th>
              <th class="text-xs uppercase tracking-wider text-blue-600 font-semibold py-3 px-4 text-left bg-blue-50">{programName}</th>
              {comparePrograms.map((program) => (
                <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-left">{program}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {compareRows.map((row) => (
              <tr>
                <td class="text-sm text-slate-500 py-3 px-4 border-b border-[#E8E4DD]">{row.feature}</td>
                <td class="text-sm font-semibold text-[#0B1120] py-3 px-4 border-b border-[#E8E4DD] bg-blue-50/50">{row.values[0]}</td>
                {row.values.slice(1).map((val) => (
                  <td class="text-sm text-[#0B1120] py-3 px-4 border-b border-[#E8E4DD]">{val}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="flex flex-wrap gap-4 mt-6">
        {compareLinks.map((link) => (
          <a href={link.href} class="text-sm text-blue-500 hover:text-blue-600 underline">{link.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 7: FAQ (Light, White) -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 mb-3">FAQ</p>
      <h2 class="text-3xl font-bold text-[#0B1120] mb-8">{programName} FAQ</h2>
      <FAQAccordion items={faqItems} client:visible />
    </div>
  </section>

  <!-- Section 8: CTA (Dark) -->
  <section class="bg-[#0B1120] py-16 md:py-24">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-amber-400 mb-3">READY?</p>
      <h2 class="text-3xl font-bold text-white mb-4">Ready for a {programName} Loan?</h2>
      <p class="text-slate-300 text-base leading-relaxed mb-8">{ctaCopy}</p>
      <a
        href={`/qualify/?program=${slug}`}
        class="inline-block bg-amber-500 hover:bg-amber-600 text-[#0B1120] font-semibold text-sm uppercase tracking-wider px-8 py-4 rounded transition-colors"
      >
        Match Me With a Specialist
      </a>
      <div class="flex flex-wrap justify-center gap-6 mt-8 text-xs text-slate-400">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          50+ DSCR Lenders
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          All 50 States
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Soft Pull Only
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          $0 Upfront Fees
        </span>
      </div>
    </div>
  </section>

</BaseLayout>
