---
import LandingLayout from '../../layouts/LandingLayout.astro';
import LPHeader from '../../components/lp/LPHeader.astro';
import HeroFL from '../../components/lp/HeroFL.astro';
import BenefitsBar from '../../components/lp/BenefitsBar.astro';
import TestimonialCarouselFL from '../../components/lp/TestimonialCarouselFL.tsx';
import SpecialistCard from '../../components/lp/SpecialistCard.astro';
import ComparisonTable from '../../components/lp/ComparisonTable.astro';
import ProgramGrid from '../../components/ProgramGrid.astro';
import FAQAccordion from '../../components/FAQAccordion.tsx';
// HowItWorksFL removed per Tanner 2026-05-26. Order: Hero, BenefitsBar, ComparisonTable, SpecialistCard, ProgramGrid, Testimonials, FAQ, FinalCTA.
import FinalCTAFL from '../../components/lp/FinalCTAFL.astro';
import LPFooter from '../../components/lp/LPFooter.astro';
import StickyMobileCTA from '../../components/lp/StickyMobileCTA.astro';
import { floridaFAQ } from '../../data/lp/florida-faq';

const PHONE = '(888) 931-0211';

const flSpecialistStats = [
  { label: 'DSCR/Non-QM Loans Closed', value: '250+' },
  { label: 'Typical Close', value: 'Fast' },
  { label: 'Lender Network', value: '70+' },
  { label: 'NMLS', value: '#312817' },
];

const flSpecialistBio = "We've closed 250+ DSCR and non-QM loans for real estate investors, including the ones whose first lender already said no. We're consultative on the first call: we walk you through condo warrantability, STR zoning, coastal exposure, and post-Surfside building issues so you know what you are working with before you write the offer.";

const title = 'Florida DSCR Loans, Consultative From Day One | Tall Timbers RFS';
const description = "Tall Timbers Realty and Financial Services has closed 250+ DSCR and non-QM loans for real estate investors. Consultative on the first call. Non-warrantable condos, STR zoning, coastal exposure handled. Qualify on rents, not tax returns.";

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: floridaFAQ.map((q) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: q.answer,
    },
  })),
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FinancialService',
  name: 'Tall Timbers RFS Florida DSCR Investor Loans',
  description,
  url: 'https://talltimbersrfs.com/lp/florida-dscr/',
  areaServed: {
    '@type': 'State',
    name: 'Florida',
  },
  provider: {
    '@type': 'Organization',
    name: 'Tall Timbers Realty and Financial Services',
  },
};
---

<LandingLayout
  title={title}
  description={description}
  noIndex={true}
  hideHeader={true}
  hideFooter={true}
  jsonLd={[serviceJsonLd, faqJsonLd]}
>
  <Fragment slot="head">
    <noscript>
      <style>
        .fl-reveal, .fl-reveal-chip { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>
  </Fragment>

  <LPHeader phoneNumber={PHONE} phoneLabel="Talk to a DSCR Specialist" />

  <HeroFL />

  <!-- 3-card benefit bar: result-language, dark forest card surface, custom SVG icons -->
  <BenefitsBar />

  <!-- Comparison up front: kills "why not go direct" while cold -->
  <ComparisonTable />

  <!-- Meet Your Specialist. Anchor panel: soft emerald tint frames the section. -->
  <section data-fl-section="specialist" class="py-20 md:py-24" style="background: linear-gradient(180deg, rgba(30,158,110,0.04) 0%, rgba(30,158,110,0.07) 100%);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">WHO YOU'RE WORKING WITH</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-navy">Tall Timbers Realty and Financial Services</h2>
      </div>
      <SpecialistCard
        variant="full"
        theme="light"
        title="DSCR Investor Loans"
        specialistLabel="Tall Timbers"
        ctaLabel="Check Your Eligibility"
        bio={flSpecialistBio}
        stats={flSpecialistStats}
        phoneNumber={PHONE}
      />
    </div>
  </section>

  <!-- Loan programs we work, photo-banner cards (links stripped, this is single-broker) -->
  <ProgramGrid />

  <!-- FL Deal Stories: dark forest-green band -->
  <section data-fl-section="testimonials" class="bg-navy py-20 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">RECENT DEALS</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">Real Deals, Real Outcomes</h2>
        <p class="mt-4 text-lg text-white/60 leading-relaxed max-w-3xl mx-auto">
          A snapshot of recent Florida deals we closed, including the file-rescue ones other brokers walked away from.
        </p>
      </div>
      <TestimonialCarouselFL client:visible />

      <!-- CTA after the testimonial emotional peak -->
      <div class="mt-12 flex flex-col items-center gap-3 sm:gap-4 sm:flex-row sm:justify-center">
        <a
          href="#lead-form"
          data-event="scroll_to_form"
          data-location="after_testimonials"
          class="inline-flex items-center justify-center rounded-lg bg-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-dark w-full sm:w-auto"
        >
          Check Your Eligibility
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={`tel:${PHONE.replace(/\D/g, '')}`}
          data-event="phone_click"
          data-location="after_testimonials"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/15 bg-white/[0.04] px-6 py-3 text-base font-medium text-white transition-colors hover:border-blue hover:bg-blue/10 w-full sm:w-auto"
        >
          <svg class="h-5 w-5 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-1.86.93a11 11 0 005.2 5.2l.93-1.86a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z" />
          </svg>
          Call {PHONE}
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section data-fl-section="faq" class="bg-off-white py-20 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">QUESTIONS</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-navy">DSCR Loan Questions</h2>
        <p class="mt-4 text-base text-gray-500">The questions investors actually ask after their first lender said no.</p>
      </div>
      <FAQAccordion items={floridaFAQ} client:visible />

      <!-- CTA after FAQ, before final close -->
      <div class="mt-12 flex flex-col items-center gap-3 sm:gap-4 sm:flex-row sm:justify-center">
        <a
          href="#lead-form"
          data-event="scroll_to_form"
          data-location="after_faq"
          class="inline-flex items-center justify-center rounded-lg bg-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-dark w-full sm:w-auto"
        >
          Check Your Eligibility
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={`tel:${PHONE.replace(/\D/g, '')}`}
          data-event="phone_click"
          data-location="after_faq"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-6 py-3 text-base font-medium text-navy transition-colors hover:border-blue hover:text-blue w-full sm:w-auto"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-1.86.93a11 11 0 005.2 5.2l.93-1.86a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z" />
          </svg>
          Call {PHONE}
        </a>
      </div>
    </div>
  </section>

  <FinalCTAFL phoneNumber={PHONE} />

  <LPFooter />

  <StickyMobileCTA phoneNumber={PHONE} />
</LandingLayout>

<!-- GSAP-driven motion for the FL LP. Lazy-loads gsap/ScrollTrigger via dynamic import and respects prefers-reduced-motion. -->
<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    Promise.all([
      import('gsap'),
      import('gsap/ScrollTrigger'),
    ]).then(([{ default: gsap }, { ScrollTrigger }]) => {
      gsap.registerPlugin(ScrollTrigger);

      // 1. Section enter fade-up on H2 heading blocks only (skip hero so H1 + form remain visible)
      const sections = document.querySelectorAll('[data-fl-section]:not([data-fl-section="hero"])');
      sections.forEach((section) => {
        const heading = section.querySelector('h2');
        if (!heading) return;
        const headingBlock = heading.parentElement || heading;
        gsap.set(headingBlock, { opacity: 0, y: 24 });
        ScrollTrigger.create({
          trigger: section,
          start: 'top 80%',
          once: true,
          onEnter: () => {
            gsap.to(headingBlock, {
              opacity: 1,
              y: 0,
              duration: 0.6,
              ease: 'power2.out',
            });
          },
        });
      });

      // 2. Hero parallax: ~10% translateY range on the bg image as user scrolls past hero
      const heroBg = document.getElementById('fl-hero-bg');
      if (heroBg) {
        gsap.to(heroBg, {
          yPercent: 10,
          ease: 'none',
          scrollTrigger: {
            trigger: '[data-fl-section="hero"]',
            start: 'top top',
            end: 'bottom top',
            scrub: true,
          },
        });
      }

      // 3. Hero trust chip stagger-in
      const heroChips = document.querySelectorAll('[data-fl-hero-chips] .fl-reveal-chip');
      if (heroChips.length) {
        gsap.to(heroChips, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          ease: 'power2.out',
          stagger: 0.08,
          delay: 0.3,
        });
      }

      // 4. FinalCTA chip stagger-in (on scroll trigger)
      const finalChips = document.querySelectorAll('[data-fl-finalcta-chips] .fl-reveal-chip');
      if (finalChips.length) {
        ScrollTrigger.create({
          trigger: '[data-fl-section="final-cta"]',
          start: 'top 80%',
          once: true,
          onEnter: () => {
            gsap.to(finalChips, {
              opacity: 1,
              y: 0,
              duration: 0.5,
              ease: 'power2.out',
              stagger: 0.08,
            });
          },
        });
      }

      // 5. HowItWorks step stagger fade-up
      const steps = document.querySelectorAll('[data-fl-step]');
      if (steps.length) {
        gsap.set(steps, { opacity: 0, y: 24 });
        ScrollTrigger.create({
          trigger: '[data-fl-section="how-it-works"]',
          start: 'top 75%',
          once: true,
          onEnter: () => {
            gsap.to(steps, {
              opacity: 1,
              y: 0,
              duration: 0.6,
              ease: 'power2.out',
              stagger: 0.12,
            });
          },
        });
      }

      // 6. Specialist stat count-up animation
      const statEls = document.querySelectorAll('[data-stat-value]');
      statEls.forEach((el) => {
        const raw = (el as HTMLElement).dataset.statValue || '';
        const match = raw.match(/^([^\d]*)(\d[\d,]*)(.*)$/);
        if (!match) return;
        const prefix = match[1];
        const numStr = match[2].replace(/,/g, '');
        const suffix = match[3];
        const target = parseInt(numStr, 10);
        if (Number.isNaN(target) || target <= 0) return;
        const obj = { v: 0 };
        ScrollTrigger.create({
          trigger: el,
          start: 'top 85%',
          once: true,
          onEnter: () => {
            gsap.to(obj, {
              v: target,
              duration: 1.2,
              ease: 'power2.out',
              onUpdate: () => {
                const display = Math.round(obj.v).toLocaleString();
                el.textContent = `${prefix}${display}${suffix}`;
              },
              onComplete: () => {
                el.textContent = raw;
              },
            });
          },
        });
      });
    });
  }
</script>
