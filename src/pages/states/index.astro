---
import BaseLayout from '../../layouts/BaseLayout.astro';
import USMap from '../../components/USMap';
import statesData from '../../data/states.json';

const title = 'DSCR Loans by State | All 50 States | DSCRBroker.com';
const description = 'Find DSCR loan programs and licensed specialists in all 50 states plus D.C. Compare median prices, rents, and estimated DSCR ratios. No income docs required.';
const canonical = 'https://dscrbroker.com/states/';

// Sort states alphabetically
const sortedStates = [...statesData].sort((a, b) => a.state.localeCompare(b.state));

// Tier 1 states for featured section
const tier1Slugs = ['texas', 'florida', 'california', 'georgia', 'north-carolina', 'new-york', 'arizona', 'tennessee', 'ohio', 'colorado'];
const tier1States = tier1Slugs.map(slug => statesData.find(s => s.slug === slug)).filter(Boolean);

function formatCurrencyShort(n: number): string {
  if (n >= 1000000) return `$${(n / 1000000).toFixed(2)}M`;
  if (n >= 1000) return `$${(n / 1000).toFixed(0)}K`;
  return `$${n}`;
}

function formatCurrency(n: number): string {
  return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
}

function dscrColor(dscr: number): string {
  if (dscr >= 1.25) return 'text-emerald-600';
  if (dscr >= 1.0) return 'text-blue-600';
  if (dscr >= 0.75) return 'text-amber-600';
  return 'text-red-600';
}

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "DSCR Loans by State",
    "description": description,
    "url": canonical,
    "provider": {
      "@type": "Organization",
      "name": "DSCRBroker.com",
      "url": "https://dscrbroker.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://dscrbroker.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "States",
        "item": canonical
      }
    ]
  }
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="bg-[#0B1120] pt-16 pb-20 overflow-hidden relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.08),transparent_70%)]" />
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="text-sm text-slate-400">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li class="text-slate-500">/</li>
          <li class="text-white">States</li>
        </ol>
      </nav>

      <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mt-6">
        DSCR Loans by State
      </h1>
      <p class="text-lg text-slate-300 max-w-3xl mt-4 leading-relaxed">
        We cover all 50 states plus D.C. through our network of licensed DSCR loan specialists. Click any state to see local market data, programs, and deal examples.
      </p>

      <!-- Interactive Map -->
      <div class="mt-10">
        <USMap client:visible />
      </div>
    </div>
  </section>

  <!-- Featured States (Tier 1) -->
  <section class="bg-[#F8F6F1] py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 mb-3">TOP DSCR MARKETS</p>
      <h2 class="text-3xl font-bold text-[#0B1120] mb-8">10 Most Active States for DSCR Investors</h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {tier1States.map((s: any) => (
          <a href={`/states/${s.slug}/`} class="group bg-white border border-[#E8E4DD] rounded-xl p-5 hover:border-blue-300 hover:shadow-md transition-all">
            <h3 class="text-sm font-bold text-[#0B1120] group-hover:text-blue-600 transition-colors">{s.state}</h3>
            <div class="mt-3 space-y-1 text-xs text-slate-500">
              <div class="flex justify-between">
                <span>Median Price</span>
                <span class="font-semibold text-[#0B1120]">{formatCurrencyShort(s.medianHomePrice)}</span>
              </div>
              <div class="flex justify-between">
                <span>Median Rent</span>
                <span class="font-semibold text-[#0B1120]">{formatCurrency(s.medianRent)}</span>
              </div>
              <div class="flex justify-between">
                <span>Est. DSCR</span>
                <span class={`font-semibold ${dscrColor(s.estimatedDSCR)}`}>{s.estimatedDSCR.toFixed(2)}x</span>
              </div>
              <div class="flex justify-between">
                <span>Tax Rate</span>
                <span class="font-semibold text-[#0B1120]">{s.propertyTaxRate}%</span>
              </div>
            </div>
            <div class="text-xs text-blue-500 mt-3 font-medium group-hover:underline">View {s.state} &rarr;</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- All States Grid -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-500 mb-3">ALL 50 STATES + DC</p>
      <h2 class="text-3xl font-bold text-[#0B1120] mb-8">DSCR Loans in Every State</h2>

      <!-- Desktop Table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-[#F8F6F1]">
              <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-left">State</th>
              <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-right">Median Price</th>
              <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-right">Median Rent</th>
              <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-right">Tax Rate</th>
              <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-right">Est. DSCR</th>
              <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-center">Landlord</th>
              <th class="text-xs uppercase tracking-wider text-slate-500 font-semibold py-3 px-4 text-right"></th>
            </tr>
          </thead>
          <tbody>
            {sortedStates.map((s: any) => (
              <tr class="border-b border-[#F0EDE8] hover:bg-[#F8F6F1]/50 transition-colors">
                <td class="py-3 px-4">
                  <a href={`/states/${s.slug}/`} class="text-sm font-semibold text-[#0B1120] hover:text-blue-600 transition-colors">{s.state}</a>
                </td>
                <td class="text-sm text-slate-600 py-3 px-4 text-right font-mono">{formatCurrencyShort(s.medianHomePrice)}</td>
                <td class="text-sm text-slate-600 py-3 px-4 text-right font-mono">{formatCurrency(s.medianRent)}</td>
                <td class="text-sm text-slate-600 py-3 px-4 text-right">{s.propertyTaxRate}%</td>
                <td class={`text-sm font-semibold py-3 px-4 text-right ${dscrColor(s.estimatedDSCR)}`}>{s.estimatedDSCR.toFixed(2)}x</td>
                <td class="py-3 px-4 text-center">
                  <span class={`inline-block text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full ${
                    s.landlordFriendly === 'friendly' ? 'bg-emerald-100 text-emerald-700' :
                    s.landlordFriendly === 'tenant' ? 'bg-amber-100 text-amber-700' :
                    'bg-blue-100 text-blue-700'
                  }`}>
                    {s.landlordFriendly === 'friendly' ? 'Friendly' : s.landlordFriendly === 'tenant' ? 'Tenant' : 'Moderate'}
                  </span>
                </td>
                <td class="py-3 px-4 text-right">
                  <a href={`/states/${s.slug}/`} class="text-xs text-blue-500 hover:text-blue-600 font-medium">View &rarr;</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile Card Grid -->
      <div class="md:hidden grid grid-cols-2 gap-3">
        {sortedStates.map((s: any) => (
          <a href={`/states/${s.slug}/`} class="group bg-[#F8F6F1] border border-[#E8E4DD] rounded-lg p-3 hover:border-blue-300 transition-all">
            <h3 class="text-xs font-bold text-[#0B1120] group-hover:text-blue-600">{s.state}</h3>
            <div class="mt-1.5 text-[10px] text-slate-500 space-y-0.5">
              <div>{formatCurrencyShort(s.medianHomePrice)} / {formatCurrency(s.medianRent)}</div>
              <div class={`font-semibold ${dscrColor(s.estimatedDSCR)}`}>DSCR: {s.estimatedDSCR.toFixed(2)}x</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#0B1120] py-16 md:py-24 relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.08),transparent_70%)]" />
    <div class="relative mx-auto max-w-2xl px-4 sm:px-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-amber-400 mb-3">GET STARTED</p>
      <h2 class="text-3xl font-bold text-white mb-4">Find Your State. Match With a Specialist.</h2>
      <p class="text-slate-300 text-base leading-relaxed mb-8">
        Select your investment state and get matched with a licensed DSCR specialist in under 2 minutes. No credit pull. No commitment.
      </p>
      <a
        href="/qualify/"
        class="inline-block bg-amber-500 hover:bg-amber-600 text-[#0B1120] font-semibold text-sm uppercase tracking-wider px-8 py-4 rounded-lg transition-colors"
      >
        Match Me With a Specialist
      </a>
      <div class="flex flex-wrap justify-center gap-6 mt-8 text-xs text-slate-400">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          50+ DSCR Lenders
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          All 50 States + DC
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Soft Pull Only
        </span>
      </div>
    </div>
  </section>

</BaseLayout>
