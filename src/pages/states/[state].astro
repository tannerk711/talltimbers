---
import StateLayout from '../../layouts/StateLayout.astro';
import statesData from '../../data/states.json';

export function getStaticPaths() {
  return statesData.map((s: any) => ({
    params: { state: s.slug },
    props: { stateData: s },
  }));
}

const { stateData } = Astro.props;

// Build related states data from slugs
const relatedStates = (stateData.relatedStates || [])
  .map((slug: string) => statesData.find((s: any) => s.slug === slug))
  .filter(Boolean)
  .map((s: any) => ({
    state: s.state,
    slug: s.slug,
    medianHomePrice: s.medianHomePrice,
    medianRent: s.medianRent,
  }));

// Build meta description
const stateFactMap: Record<string, string> = {
  TX: 'No state income tax. Four top-20 metros.',
  FL: 'No state income tax. Top STR market in the nation.',
  CA: 'Largest rental market in the US. Strong appreciation.',
  GA: 'Atlanta leads Southeast growth. Landlord-friendly.',
  NC: 'Research Triangle tech boom. Charlotte banking hub.',
  NY: 'Upstate cash flow. NYC appreciation.',
  AZ: 'Landlord-friendly. Low property taxes at 0.63%.',
  TN: 'No state income tax. Smoky Mountain STR goldmine.',
  OH: 'Three metros. Ultra-affordable cash flow.',
  CO: 'Tech economy. Mountain resort STR markets.',
};
const stateFact = stateFactMap[stateData.abbreviation] || `${stateData.landlordFriendly === 'friendly' ? 'Landlord-friendly laws.' : stateData.landlordFriendly === 'tenant' ? 'Strong rental demand.' : 'Steady rental market.'} Property tax at ${stateData.propertyTaxRate}%.`;
const metaDescription = `DSCR loans in ${stateData.state} from a licensed specialist. ${stateFact} No income docs. Match with a ${stateData.state} DSCR specialist at DSCRBroker.com.`;

// Build title
const title = `DSCR Loans in ${stateData.state} | Licensed Specialist | DSCRBroker.com`;

// Build JSON-LD (3 schemas: FinancialService, FAQPage, BreadcrumbList)
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "name": `DSCR Loans in ${stateData.state} | DSCRBroker.com`,
    "url": `https://dscrbroker.com/states/${stateData.slug}/`,
    "description": `DSCR loans in ${stateData.state} structured by licensed DSCR specialists. Access to 50+ lenders. No income documentation required.`,
    "serviceType": "DSCR Loan Broker Matching",
    "areaServed": {
      "@type": "State",
      "name": stateData.state,
      "containedInPlace": {
        "@type": "Country",
        "name": "United States"
      }
    },
    "provider": {
      "@type": "Organization",
      "name": "DSCRBroker.com",
      "url": "https://dscrbroker.com"
    },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "USD",
      "lowPrice": "75000",
      "highPrice": "3000000",
      "offerCount": "8"
    },
    "address": {
      "@type": "PostalAddress",
      "addressRegion": stateData.abbreviation,
      "addressCountry": "US"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": stateData.faqItems.map((item: any) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://dscrbroker.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "States",
        "item": "https://dscrbroker.com/states/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": `DSCR Loans in ${stateData.state}`,
        "item": `https://dscrbroker.com/states/${stateData.slug}/`
      }
    ]
  }
];
---

<StateLayout
  title={title}
  description={metaDescription}
  slug={stateData.slug}
  abbreviation={stateData.abbreviation}
  state={stateData.state}
  stateHook={stateData.stateHook}
  medianHomePrice={stateData.medianHomePrice}
  medianRent={stateData.medianRent}
  estimatedDSCR={stateData.estimatedDSCR}
  marketOverview={stateData.marketOverview}
  landlordFriendly={stateData.landlordFriendly}
  propertyTaxRate={stateData.propertyTaxRate}
  topCities={stateData.topCities}
  commonPropertyTypes={stateData.commonPropertyTypes}
  licensingNote={stateData.licensingNote}
  dealExample={stateData.dealExample}
  faqItems={stateData.faqItems}
  relatedStates={relatedStates}
  jsonLd={jsonLd}
/>
