---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThankYou from '../components/form/ThankYou';

const title = "You're Matched | DSCRBroker.com";
const description = 'Your DSCR specialist will reach out shortly to verify a few details and structure your file for the right lender.';
---

<BaseLayout title={title} description={description} noIndex={true}>
  <section class="relative bg-navy py-24 md:py-32 min-h-screen">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 30%, #131C31 0%, #0B1120 70%);" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <ThankYou client:load />
    </div>
  </section>
</BaseLayout>
