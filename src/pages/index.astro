---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'DSCR Investor Loans in Florida and Georgia | Tall Timbers RFS';
const description = "Tall Timbers Realty and Financial Services has closed 250+ DSCR and non-QM loans for real estate investors. Consultative on the first call. 70+ lender network. Qualify on rents, not tax returns.";

const PHONE = '(888) 931-0211';
const phoneHref = `tel:${PHONE.replace(/\D/g, '')}`;

const states = [
  {
    name: 'Florida',
    slug: 'florida',
    href: '/lp/florida-dscr/',
    image: '/images/sections/florida-hero.jpg',
    tagline: 'Non-warrantable condos, STR zoning, coastal exposure handled.',
  },
  {
    name: 'Georgia',
    slug: 'georgia',
    href: '/lp/georgia-dscr/',
    image: '/images/sections/georgia-hero.jpg',
    tagline: 'STR zoning, BRRRR refi timing, property tax appeals handled.',
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FinancialService",
  "name": "Tall Timbers Realty and Financial Services",
  "description": "DSCR investor loan brokerage. 250+ closed DSCR and non-QM loans across a 70+ lender network. Licensed Mortgage Loan Originator NMLS #312817.",
  "url": "https://talltimbersrfs.com",
  "telephone": PHONE,
  "areaServed": [
    { "@type": "State", "name": "Florida" },
    { "@type": "State", "name": "Georgia" }
  ],
  "provider": {
    "@type": "Organization",
    "name": "Tall Timbers Realty and Financial Services"
  }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 30%, rgba(30,158,110,0.18) 0%, transparent 60%);"></div>
      <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(63,199,147,0.10) 0%, transparent 70%);"></div>
      <div class="absolute -bottom-40 -left-40 w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(200,147,44,0.06) 0%, transparent 70%);"></div>
    </div>

    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 rounded-full bg-blue/15 border border-blue/30 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-blue-light">
        DSCR Investor Loans
      </span>

      <h1 class="mt-6 text-3xl font-extrabold tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl" style="line-height: 1.05;">
        Qualify on Rents. Not Tax Returns.
      </h1>

      <p class="mt-6 max-w-2xl mx-auto text-lg leading-relaxed text-white/70">
        We've closed 250+ DSCR and non-QM loans for real estate investors. We're consultative on the first call, walk you through what works, and route your file to the right lender in our 70+ lender network.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 sm:justify-center">
        <a href="#states" class="inline-flex items-center justify-center rounded-lg bg-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-dark">
          Check Your Eligibility
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href={phoneHref} class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/20 bg-white/[0.04] px-6 py-3 text-base font-medium text-white transition-colors hover:border-blue hover:bg-blue/10">
          <svg class="h-5 w-5 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.5 4.49a1 1 0 01-.5 1.21l-1.86.93a11 11 0 005.2 5.2l.93-1.86a1 1 0 011.21-.5l4.49 1.5a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.72 21 3 14.28 3 6V5z" />
          </svg>
          Call {PHONE}
        </a>
      </div>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-white/60">
        <span class="flex items-center gap-1.5">
          <svg class="h-4 w-4 text-blue-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          250+ DSCR/Non-QM Loans Closed
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-4 w-4 text-blue-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          70+ Lender Network
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-4 w-4 text-blue-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Licensed MLO NMLS #312817
        </span>
      </div>
    </div>
  </section>

  <!-- State LPs -->
  <section id="states" class="bg-off-white py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center mb-12">
        <p class="text-xs font-medium uppercase tracking-[0.1em] text-amber mb-3">Where We Work</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-navy">Pick Your State to Get Started</h2>
        <p class="mt-4 text-lg text-gray-500">We close DSCR loans for investors in Florida and Georgia. Check your eligibility in 60 seconds.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {states.map((state) => (
          <a href={state.href} class="group relative overflow-hidden rounded-2xl shadow-lg ring-1 ring-gray-200 bg-white transition-all duration-300 hover:shadow-2xl hover:-translate-y-1">
            <div class="relative h-64 md:h-72 overflow-hidden">
              <img src={state.image} alt={`${state.name} investor properties`} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" decoding="async" />
              <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(7,38,15,0.20) 0%, rgba(7,38,15,0.78) 100%);"></div>
              <div class="absolute bottom-0 left-0 right-0 p-7 md:p-8">
                <p class="text-xs font-semibold uppercase tracking-wider text-blue-light mb-1.5">DSCR in</p>
                <h3 class="text-3xl md:text-4xl font-extrabold text-white">{state.name}</h3>
              </div>
            </div>
            <div class="p-6 md:p-7 flex items-center justify-between gap-4">
              <p class="text-sm md:text-[15px] text-gray-600 leading-relaxed">{state.tagline}</p>
              <span class="flex-shrink-0 inline-flex items-center justify-center h-10 w-10 rounded-full bg-blue text-white transition-transform duration-300 group-hover:translate-x-1">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
