---
import ProgramLayout from '../../layouts/ProgramLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FinancialProduct",
    "name": "Portfolio DSCR Loan",
    "description": "Blanket DSCR loans covering 3+ investment properties on a single loan. Simplified management and one monthly payment for your rental portfolio. Available in all 50 states.",
    "url": "https://dscrbroker.com/programs/portfolio-dscr",
    "provider": { "@type": "Organization", "name": "DSCRBroker.com", "url": "https://dscrbroker.com" },
    "offers": { "@type": "AggregateOffer", "priceCurrency": "USD", "lowPrice": "500000", "highPrice": "10000000", "description": "DSCR loan program for real estate investors. Qualifies on property cash flow, not personal income" },
    "areaServed": { "@type": "Country", "name": "United States" },
    "category": "DSCR Mortgage Loan",
    "feesAndCommissionsSpecification": "Loan terms and fees vary by lender. DSCRBroker.com does not charge borrowers any fees."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is the minimum number of properties?", "acceptedAnswer": { "@type": "Answer", "text": "Most portfolio DSCR lenders require a minimum of 3 properties. Some will do 2 if the combined loan amount exceeds $500,000. There is no practical maximum, though lenders typically batch 20-30 properties per loan." } },
      { "@type": "Question", "name": "Do all properties need to be in the same state?", "acceptedAnswer": { "@type": "Answer", "text": "No. Properties can be in different states, different cities, and different property types (SFR, condo, 2-4 unit). The lender evaluates the portfolio as a whole." } },
      { "@type": "Question", "name": "Can I add properties to the portfolio later?", "acceptedAnswer": { "@type": "Answer", "text": "Not to an existing portfolio loan. You would need a new loan for additional properties. If you want to consolidate new acquisitions with your existing portfolio, you can refinance the entire batch into a new portfolio loan." } },
      { "@type": "Question", "name": "What happens if I want to sell one property from the portfolio?", "acceptedAnswer": { "@type": "Answer", "text": "Portfolio loans include release clauses. You pay the lender a release price (typically 110-125% of that property's allocated loan amount) and the property is released from the blanket mortgage. The remaining properties stay in the loan." } },
      { "@type": "Question", "name": "How does Portfolio DSCR pricing compare to individual loans?", "acceptedAnswer": { "@type": "Answer", "text": "The scale of the loan amount ($500K-$10M+) gives lenders more margin, so program terms can be favorable. Closing costs are higher because each property requires its own appraisal and title search. Your specialist will compare bundled vs. individual loan structures for your specific portfolio." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dscrbroker.com" },
      { "@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://dscrbroker.com/programs" },
      { "@type": "ListItem", "position": 3, "name": "Portfolio DSCR Loans", "item": "https://dscrbroker.com/programs/portfolio-dscr" }
    ]
  }
];
---

<ProgramLayout
  title="Portfolio DSCR Loans | DSCRBroker.com"
  description="Portfolio DSCR loans for 5+ properties on one loan. Blanket financing for rental portfolios. Match with a specialist who structures portfolio DSCR deals."
  slug="portfolio-dscr"
  heroImage="/images/programs/portfolio-dscr.jpg"
  programName="Portfolio DSCR"
  h1="Portfolio DSCR Loans"
  subhead="One loan. One payment. One closing. Consolidate 3 or more investment properties under a single blanket DSCR loan and simplify your portfolio."
  stats={[
    { value: '1.0x', label: 'Aggregate DSCR' },
    { value: '25%', label: 'Min Down' },
    { value: '680', label: 'Min FICO' },
    { value: '75%', label: 'Max LTV' },
  ]}
  howItWorks={[
    "The Portfolio DSCR loan is a blanket mortgage covering multiple investment properties under one loan. Instead of financing each property individually, the lender evaluates the entire portfolio as a package. The DSCR is calculated on the aggregate rental income and aggregate PITIA across all properties.",
    "This means a property with a 0.85x DSCR can be included in the portfolio as long as the overall portfolio DSCR is 1.0x or higher. Strong cash-flowing properties offset weaker ones.",
    "Properties can be in different states, different property types, and different markets. The lender appraises each property individually but underwrites them as a single loan. Closings take 30-45 days due to the number of appraisals and title searches involved.",
    "Release clauses allow you to sell individual properties from the portfolio without paying off the entire loan. The lender specifies a release price (typically 110-125% of the allocated loan amount for that property). This gives you the flexibility to rotate properties out of the portfolio as your strategy evolves."
  ]}
  qualifyItems={[
    { text: 'You own 3 or more investment properties you want to consolidate' },
    { text: 'Your aggregate portfolio DSCR is 1.0x or higher across all included properties' },
    { text: 'Your FICO score is 680 or higher' },
    { text: 'You have 25%+ equity across the portfolio (or 25% down for a purchase portfolio)' },
    { text: 'Your combined loan amount is $500,000 or more' },
    { text: 'You want one monthly payment instead of multiple separate mortgages' },
    { text: 'You want to pull cash out of an entire portfolio at once' },
  ]}
  notRightItems={[
    { text: 'You have fewer than 3 investment properties' },
    { text: 'Your combined loan amount is below $500,000' },
    { text: 'You want to sell individual properties frequently without restriction' },
    { text: 'Your aggregate DSCR across all properties is below 1.0x' },
    { text: 'Your FICO score is below 680' },
  ]}
  dealInvestor="Robert T., Ohio"
  dealProperty="6 single-family rentals in Columbus, OH"
  dealDetails={[
    { label: 'Total Portfolio Value', value: '$1,380,000' },
    { label: 'Existing Liens', value: '$0 (free and clear)' },
    { label: 'Cash-Out Loan Amount', value: '$966,000 (70% LTV)' },
    { label: 'Properties', value: '6 SFRs' },
  ]}
  dealBreakdown={[
    { label: 'Monthly P&I (total)', value: '$6,674' },
    { label: 'Property Taxes (total)', value: '$1,725' },
    { label: 'Insurance (total)', value: '$660' },
    { label: 'HOA', value: '$0' },
    { label: 'Total PITIA', value: '$9,059', highlight: true },
    { label: 'Total Monthly Rent', value: '$10,800', highlight: true },
  ]}
  dealDscr="1.19x"
  dealDscrColor="text-emerald-500"
  dealCashFlow="+$1,741/mo"
  dealCashFlowPositive={true}
  dealCloseTime="30 days"
  dealMathLine="Total Rent ($10,800) ÷ Total PITIA ($9,059) = 1.19x Portfolio DSCR"
  dealQuote="I had six properties with no debt and no liquidity. My broker put them all under one DSCR loan, handed me $966K in cash, and the portfolio still cash flows $1,741 a month. I went from 6 properties to a plan for 10."
  dealQuoteAttribution="Robert T., Ohio"
  comparePrograms={['Standard DSCR', 'Bridge-to-DSCR']}
  compareRows={[
    { feature: 'Min DSCR', values: ['1.0x (aggregate)', '1.0x', 'None (bridge) / 1.0x (perm)'] },
    { feature: 'Min Down Payment', values: ['25%', '20%', '15% (bridge) / 20% (perm)'] },
    { feature: 'Min FICO', values: ['680', '660', '660'] },
    { feature: 'Best For', values: ['3+ property bundles', 'Cash-flowing rentals', 'BRRRR investors'] },
    { feature: 'Unique Feature', values: ['Aggregate DSCR across portfolio', 'No income docs, no property cap', 'Two-phase: bridge + permanent'] },
  ]}
  compareLinks={[
    { label: 'Learn more about Standard DSCR Loans', href: '/programs/standard-dscr' },
    { label: 'Learn more about Bridge-to-DSCR Loans', href: '/programs/bridge-to-dscr' },
  ]}
  faqItems={[
    { question: 'What is the minimum number of properties?', answer: 'Most portfolio DSCR lenders require a minimum of 3 properties. Some will do 2 if the combined loan amount exceeds $500,000. There is no practical maximum, though lenders typically batch 20-30 properties per loan.' },
    { question: 'Do all properties need to be in the same state?', answer: 'No. Properties can be in different states, different cities, and different property types (SFR, condo, 2-4 unit). The lender evaluates the portfolio as a whole.' },
    { question: 'Can I add properties to the portfolio later?', answer: 'Not to an existing portfolio loan. You would need a new loan for additional properties. If you want to consolidate new acquisitions with your existing portfolio, you can refinance the entire batch into a new portfolio loan.' },
    { question: 'What happens if I want to sell one property from the portfolio?', answer: "Portfolio loans include release clauses. You pay the lender a release price (typically 110-125% of that property's allocated loan amount) and the property is released from the blanket mortgage. The remaining properties stay in the loan." },
    { question: 'How does Portfolio DSCR pricing compare to individual loans?', answer: 'The scale of the loan amount ($500K-$10M+) gives lenders more margin, so program terms can be favorable. Closing costs are higher because each property requires its own appraisal and title search. Your specialist will compare bundled vs. individual loan structures for your specific portfolio.' },
  ]}
  ctaCopy="One loan. One payment. One closing. Consolidate your rental portfolio with a specialist who structures portfolio DSCR deals."
  jsonLd={jsonLd}
/>
