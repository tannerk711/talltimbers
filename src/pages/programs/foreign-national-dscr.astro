---
import ProgramLayout from '../../layouts/ProgramLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FinancialProduct",
    "name": "Foreign National DSCR Loan",
    "description": "DSCR loans for non-US citizens. No SSN required. Foreign bank statements and credit reports accepted. Available in all 50 states.",
    "url": "https://dscrbroker.com/programs/foreign-national-dscr",
    "provider": { "@type": "Organization", "name": "DSCRBroker.com", "url": "https://dscrbroker.com" },
    "offers": { "@type": "AggregateOffer", "priceCurrency": "USD", "lowPrice": "100000", "highPrice": "2000000", "description": "DSCR loan program for real estate investors. Qualifies on property cash flow, not personal income" },
    "areaServed": { "@type": "Country", "name": "United States" },
    "category": "DSCR Mortgage Loan",
    "feesAndCommissionsSpecification": "Loan terms and fees vary by lender. DSCRBroker.com does not charge borrowers any fees."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do I need a US Social Security number?", "acceptedAnswer": { "@type": "Answer", "text": "No. You will need an ITIN (Individual Taxpayer Identification Number) for tax purposes. Your broker can help you apply for one during the loan process. It does not delay closing." } },
      { "@type": "Question", "name": "Can I manage the property remotely from my home country?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Most foreign national investors hire a local property management company. The management company handles tenant relations, maintenance, and rent collection. Rent is deposited to your US bank account." } },
      { "@type": "Question", "name": "What countries are eligible?", "acceptedAnswer": { "@type": "Answer", "text": "Most countries are eligible. Lenders in our network fund loans for investors from Canada, the UK, Germany, France, Australia, Mexico, Brazil, Colombia, China, Japan, South Korea, India, and many others. Some lenders restrict borrowers from OFAC-sanctioned countries." } },
      { "@type": "Question", "name": "Are Foreign National DSCR loans harder to qualify for?", "acceptedAnswer": { "@type": "Answer", "text": "They require more documentation than a standard DSCR loan (a foreign credit report or bank reference letter, a US bank account, and an ITIN), but they do not require US credit history, an SSN, or US employment. A strong down payment (30%+) and a positive DSCR strengthen the file and broaden program access." } },
      { "@type": "Question", "name": "Can I close in an LLC?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Foreign nationals can form a US LLC (typically in the state where the property is located or in Wyoming/Delaware) and close in the entity name. An international tax advisor is recommended to structure the entity correctly for tax treaty benefits." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dscrbroker.com" },
      { "@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://dscrbroker.com/programs" },
      { "@type": "ListItem", "position": 3, "name": "Foreign National DSCR Loans", "item": "https://dscrbroker.com/programs/foreign-national-dscr" }
    ]
  }
];
---

<ProgramLayout
  title="Foreign National DSCR Loans | DSCRBroker.com"
  description="DSCR loans for non-US citizens. No SSN required. Foreign bank statements accepted. Match with a licensed specialist who structures Foreign National DSCR deals."
  slug="foreign-national-dscr"
  heroImage="/images/programs/foreign-national-dscr.jpg"
  programName="Foreign National DSCR"
  h1="Foreign National DSCR Loans"
  subhead="No US credit history required. No Social Security number. No US employment. If you're an international investor buying US rental property, this program was built for you."
  stats={[
    { value: '1.0x', label: 'Min DSCR' },
    { value: '25%', label: 'Min Down' },
    { value: 'N/A', label: 'US Credit' },
    { value: '75%', label: 'Max LTV' },
  ]}
  howItWorks={[
    "The Foreign National DSCR program is built for investors who live outside the United States. The lender uses a foreign credit report (from the borrower's home country) or a bank reference letter from a reputable foreign bank in place of a US credit score. The property still needs to meet DSCR requirements (1.0x for most lenders, though No-Ratio options exist at 30%+ down).",
    "The borrower must open a US bank account to service the loan. Many investors open an account at a US bank with international branches (Chase, Citibank, HSBC) before closing. Rental income is deposited into this account and mortgage payments are auto-debited.",
    "Documentation is straightforward: valid passport, foreign credit report or bank reference letter, proof of down payment funds, and an ITIN (Individual Taxpayer Identification Number) for tax purposes. The ITIN can be applied for during the loan process and does not delay closing.",
    "Closings can be handled remotely via a power of attorney in some cases, though most lenders prefer the borrower to be present at closing or to sign at a US consulate or embassy. Most foreign national investors hire a local property management company to handle tenant relations, maintenance, and rent collection."
  ]}
  qualifyItems={[
    { text: 'You are a non-US citizen buying US investment property' },
    { text: 'You have a valid passport (not expired)' },
    { text: 'You can provide a foreign credit report or bank reference letter from a foreign bank' },
    { text: 'You have 25-30% for a down payment plus proof of funds' },
    { text: 'You can open a US bank account for loan servicing' },
    { text: 'Your target property has a 1.0x+ DSCR (or you have 30%+ down for No-Ratio)' },
    { text: 'You can obtain an ITIN for tax purposes (your broker can assist)' },
  ]}
  notRightItems={[
    { text: 'You are a US citizen or permanent resident (Standard DSCR would offer better terms)' },
    { text: 'You cannot provide any form of credit history or bank reference from your home country' },
    { text: 'You are from an OFAC-sanctioned country (broker will confirm eligibility)' },
    { text: 'You are looking for owner-occupied financing in the US' },
  ]}
  dealInvestor="Carlos V., Florida"
  dealProperty="Single-family rental in Cape Coral, FL"
  dealDetails={[
    { label: 'Purchase Price', value: '$390,000' },
    { label: 'Down Payment', value: '30% ($117,000)' },
    { label: 'Loan Amount', value: '$273,000' },
    { label: 'Term', value: '30-year fixed' },
  ]}
  dealBreakdown={[
    { label: 'Monthly P&I', value: '$1,959' },
    { label: 'Property Taxes', value: '$569' },
    { label: 'Insurance', value: '$210' },
    { label: 'HOA', value: '$0' },
    { label: 'Total PITIA', value: '$2,738', highlight: true },
    { label: 'Monthly Gross Rent', value: '$2,900', highlight: true },
  ]}
  dealDscr="1.06x"
  dealDscrColor="text-emerald-500"
  dealCashFlow="+$162/mo"
  dealCashFlowPositive={true}
  dealCloseTime="28 days"
  dealMathLine="Monthly Rent ($2,900) ÷ Monthly PITIA ($2,738) = 1.06x DSCR"
  dealQuote="I'm Canadian. I expected a nightmare buying in the US. My broker handled the foreign bank letter, the credit report translation, everything. Twenty-eight days, start to finish. I'm already looking at my second property."
  dealQuoteAttribution="Carlos V., Florida"
  comparePrograms={['Standard DSCR', 'No-Ratio DSCR']}
  compareRows={[
    { feature: 'Min DSCR', values: ['1.0x', '1.0x', 'None'] },
    { feature: 'Min Down Payment', values: ['25-30%', '20%', '30%'] },
    { feature: 'Min FICO', values: ['No US credit required', '660', '680'] },
    { feature: 'Best For', values: ['Non-US investors', 'Cash-flowing rentals', 'Negative cash flow deals'] },
    { feature: 'Unique Feature', values: ['No US credit needed', 'No income docs, no property cap', 'No DSCR calculated'] },
  ]}
  compareLinks={[
    { label: 'Learn more about Standard DSCR Loans', href: '/programs/standard-dscr' },
    { label: 'Learn more about No-Ratio DSCR Loans', href: '/programs/no-ratio-dscr' },
  ]}
  faqItems={[
    { question: 'Do I need a US Social Security number?', answer: 'No. You will need an ITIN (Individual Taxpayer Identification Number) for tax purposes. Your broker can help you apply for one during the loan process. It does not delay closing.' },
    { question: 'Can I manage the property remotely from my home country?', answer: 'Yes. Most foreign national investors hire a local property management company. The management company handles tenant relations, maintenance, and rent collection. Rent is deposited to your US bank account. Mortgage payments are auto-debited.' },
    { question: 'What countries are eligible?', answer: 'Most countries are eligible. Lenders in our network fund loans for investors from Canada, the UK, Germany, France, Australia, Mexico, Brazil, Colombia, China, Japan, South Korea, India, and many others. Some lenders restrict borrowers from OFAC-sanctioned countries. Your broker will confirm eligibility based on your nationality.' },
    { question: 'Are Foreign National DSCR loans harder to qualify for?', answer: 'They require more documentation than a standard DSCR loan (a foreign credit report or bank reference letter, a US bank account, and an ITIN), but they do not require US credit history, an SSN, or US employment. A strong down payment (30%+) and a positive DSCR strengthen the file and broaden program access.' },
    { question: 'Can I close in an LLC?', answer: 'Yes. Foreign nationals can form a US LLC (typically in the state where the property is located or in Wyoming/Delaware) and close in the entity name. An international tax advisor is recommended to structure the entity correctly for tax treaty benefits.' },
  ]}
  ctaCopy="International investors close US rental property loans through our broker network every month. No US credit required. Get matched with a specialist who has done these deals."
  jsonLd={jsonLd}
/>
