---
import ProgramLayout from '../../layouts/ProgramLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FinancialProduct",
    "name": "Short-Term Rental DSCR Loan",
    "description": "DSCR loans for Airbnb and vacation rental properties. Qualify using projected short-term rental income from platforms like AirDNA. Available in all 50 states.",
    "url": "https://dscrbroker.com/programs/str-dscr",
    "provider": { "@type": "Organization", "name": "DSCRBroker.com", "url": "https://dscrbroker.com" },
    "offers": { "@type": "AggregateOffer", "priceCurrency": "USD", "lowPrice": "75000", "highPrice": "2000000", "description": "DSCR loan program for real estate investors. Qualifies on property cash flow, not personal income" },
    "areaServed": { "@type": "Country", "name": "United States" },
    "category": "DSCR Mortgage Loan",
    "feesAndCommissionsSpecification": "Loan terms and fees vary by lender. DSCRBroker.com does not charge borrowers any fees."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do I need an existing rental history to get an STR DSCR loan?", "acceptedAnswer": { "@type": "Answer", "text": "No. For new purchases, lenders accept an AirDNA report or appraiser STR income analysis as projected income. You do not need to already be operating the property as an STR." } },
      { "@type": "Question", "name": "Does the lender verify that the property allows short-term rentals?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The lender or their counsel will confirm that the property is in a jurisdiction that allows short-term rentals and that no HOA restrictions prohibit STR use. Some lenders require a copy of the local STR permit or license if one is required." } },
      { "@type": "Question", "name": "Why is the down payment sometimes 25% instead of 20%?", "acceptedAnswer": { "@type": "Answer", "text": "Some lenders require 25% down for STR properties because STR income is more volatile than long-term rental income. Higher occupancy risk means the lender wants more equity protection. Your broker will find lenders offering 20% down if your FICO and DSCR are strong." } },
      { "@type": "Question", "name": "Can I use projected income from multiple platforms?", "acceptedAnswer": { "@type": "Answer", "text": "The AirDNA report is the standard. It aggregates data from Airbnb, VRBO, and other booking platforms to project income. If you have actual booking history, most lenders accept combined income from all platforms you list on." } },
      { "@type": "Question", "name": "What markets work best for STR DSCR loans?", "acceptedAnswer": { "@type": "Answer", "text": "High-tourism destinations with consistent STR demand: Smoky Mountains (TN), Gulf Coast (FL), Scottsdale (AZ), Joshua Tree (CA), Big Bear (CA), Outer Banks (NC), Poconos (PA), ski towns (CO, UT). Markets with strong AirDNA data and proven STR track records get the smoothest approvals." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dscrbroker.com" },
      { "@type": "ListItem", "position": 2, "name": "Loan Programs", "item": "https://dscrbroker.com/programs" },
      { "@type": "ListItem", "position": 3, "name": "Short-Term Rental DSCR Loans", "item": "https://dscrbroker.com/programs/str-dscr" }
    ]
  }
];
---

<ProgramLayout
  title="Short-Term Rental DSCR Loans | DSCRBroker.com"
  description="DSCR loans for Airbnb and short-term rentals. Qualify using STR income projections. Match with a licensed DSCR specialist who structures your deal.com."
  slug="str-dscr"
  heroImage="/images/programs/str-dscr.jpg"
  programName="Short-Term Rental DSCR"
  h1="Short-Term Rental DSCR Loans"
  subhead="Finance your Airbnb, VRBO, or vacation rental with projected STR income. Use AirDNA reports or 12-month rental history to qualify."
  stats={[
    { value: '1.0x', label: 'Min DSCR' },
    { value: '20%', label: 'Min Down' },
    { value: '680', label: 'Min FICO' },
    { value: '80%', label: 'Max LTV' },
  ]}
  howItWorks={[
    "The STR DSCR program accepts short-term rental income where most DSCR lenders only accept long-term leases. Income is documented in one of three ways: an AirDNA report (third-party projected income based on comparable STR properties), 12-month Airbnb/VRBO booking history (actual revenue for refinances), or an appraiser STR income analysis.",
    "Most lenders use the lesser of the documented income source and apply a vacancy/expense factor (typically 25-30% reduction from gross STR income). This adjusted figure is the qualifying rent used in the DSCR calculation.",
    "Some lenders require 25% down for STR properties because STR income is more volatile than long-term rental income. Stronger FICO scores and DSCR ratios can unlock 20% down options through specific lenders in the network.",
    "The lender or their counsel will confirm that the property is in a jurisdiction that allows short-term rentals and that no HOA restrictions prohibit STR use. Some lenders require a copy of the local STR permit or license if one is required by the municipality."
  ]}
  qualifyItems={[
    { text: 'You are buying or refinancing an Airbnb, VRBO, or vacation rental' },
    { text: 'Your property is in a market with documented STR demand' },
    { text: 'You have an AirDNA report or 12 months of booking history' },
    { text: 'Your FICO score is 680 or higher' },
    { text: 'You can put 20-25% down' },
    { text: "Your property's jurisdiction allows short-term rentals" },
    { text: 'No HOA restrictions prohibit STR use on the property' },
  ]}
  notRightItems={[
    { text: 'Your local municipality has banned or severely restricted short-term rentals' },
    { text: 'Your HOA prohibits STR use and there is no variance process' },
    { text: 'You have no AirDNA data or rental history to document STR income' },
    { text: 'Your FICO score is below 680' },
    { text: 'You are operating an unpermitted STR in a market that requires a license' },
  ]}
  dealInvestor="Mike L., Tennessee"
  dealProperty="3BR/2BA cabin near Gatlinburg, TN"
  dealDetails={[
    { label: 'Purchase Price', value: '$465,000' },
    { label: 'Down Payment', value: '25% ($116,250)' },
    { label: 'Loan Amount', value: '$348,750' },
    { label: 'Term', value: '30-year fixed' },
  ]}
  dealBreakdown={[
    { label: 'Monthly P&I', value: '$2,380' },
    { label: 'Property Taxes', value: '$291' },
    { label: 'Insurance', value: '$185' },
    { label: 'HOA', value: '$0' },
    { label: 'Total PITIA', value: '$2,856', highlight: true },
    { label: 'Monthly STR Income (adj.)', value: '$4,200', highlight: true },
  ]}
  dealDscr="1.47x"
  dealDscrColor="text-emerald-500"
  dealCashFlow="+$1,344/mo"
  dealCashFlowPositive={true}
  dealCloseTime="23 days"
  dealMathLine="Monthly STR Income ($4,200) ÷ Monthly PITIA ($2,856) = 1.47x DSCR"
  dealQuote="Every lender I called said they don't count Airbnb income. My broker found one that uses AirDNA projections. A Gatlinburg cabin at 1.47x DSCR? I'm buying another one this spring."
  dealQuoteAttribution="Mike L., Tennessee"
  dealNote="STR income was documented using AirDNA market data and trailing 12-month revenue from comparable cabins within 2 miles. The lender accepted projected STR income rather than requiring a traditional lease."
  comparePrograms={['Standard DSCR', 'Interest-Only DSCR']}
  compareRows={[
    { feature: 'Min DSCR', values: ['1.0x', '1.0x', '1.0x'] },
    { feature: 'Min Down Payment', values: ['20-25%', '20%', '20%'] },
    { feature: 'Min FICO', values: ['680', '660', '680'] },
    { feature: 'Best For', values: ['Airbnb/VRBO operators', 'Cash-flowing rentals', 'Cash flow maximizers'] },
    { feature: 'Unique Feature', values: ['AirDNA projections accepted', 'No income docs, no property cap', 'Lower payments boost DSCR'] },
  ]}
  compareLinks={[
    { label: 'Learn more about Standard DSCR Loans', href: '/programs/standard-dscr' },
    { label: 'Learn more about Interest-Only DSCR Loans', href: '/programs/interest-only-dscr' },
  ]}
  faqItems={[
    { question: 'Do I need an existing rental history to get an STR DSCR loan?', answer: 'No. For new purchases, lenders accept an AirDNA report or appraiser STR income analysis as projected income. You do not need to already be operating the property as an STR.' },
    { question: 'Does the lender verify that the property allows short-term rentals?', answer: 'Yes. The lender or their counsel will confirm that the property is in a jurisdiction that allows short-term rentals and that no HOA restrictions prohibit STR use. Some lenders require a copy of the local STR permit or license if one is required.' },
    { question: 'Why is the down payment sometimes 25% instead of 20%?', answer: 'Some lenders require 25% down for STR properties because STR income is more volatile than long-term rental income. Higher occupancy risk means the lender wants more equity protection. Your broker will find lenders offering 20% down if your FICO and DSCR are strong.' },
    { question: 'Can I use projected income from multiple platforms?', answer: 'The AirDNA report is the standard. It aggregates data from Airbnb, VRBO, and other booking platforms to project income. If you have actual booking history, most lenders accept combined income from all platforms you list on.' },
    { question: 'What markets work best for STR DSCR loans?', answer: 'High-tourism destinations with consistent STR demand: Smoky Mountains (TN), Gulf Coast (FL), Scottsdale (AZ), Joshua Tree (CA), Big Bear (CA), Outer Banks (NC), Poconos (PA), ski towns (CO, UT). Markets with strong AirDNA data and proven STR track records get the smoothest approvals.' },
  ]}
  ctaCopy="Your Airbnb income counts. Get matched with a specialist who structures STR DSCR deals. Soft pull only."
  jsonLd={jsonLd}
/>
